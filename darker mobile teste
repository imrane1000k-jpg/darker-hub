-- Auto Steal
local isStealing = false
local autoStealConn = nil

local function findNearestPrompt()
local h = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
if not h then return nil end
local plots = workspace:FindFirstChild("Plots")
if not plots then return nil end
local nearest = nil
local nearestDist = math.huge
for _, plot in ipairs(plots:GetChildren()) do
local podiums = plot:FindFirstChild("AnimalPodiums")
if podiums then
for _, pod in ipairs(podiums:GetChildren()) do
local base = pod:FindFirstChild("Base")
local spawn = base and base:FindFirstChild("Spawn")
if spawn then
local dist = (spawn.Position - h.Position).Magnitude
if dist < nearestDist and dist <= AutoStealValues.STEAL_RADIUS then
local att = spawn:FindFirstChild("PromptAttachment")
if att then
for _, ch in ipairs(att:GetChildren()) do
if ch:IsA("ProximityPrompt") then
nearestDist = dist
nearest = ch
break
end
end
end
end
end
end
end
end
return nearest
end

local function executeSteal(prompt)
if isStealing then return end
isStealing = true
stealStartTime = tick()
if ProgressLabel then ProgressLabel.Text = "STEALING..." end
if progressConn then progressConn:Disconnect() end
progressConn = RunService.Heartbeat:Connect(function()
if not isStealing then
if progressConn then progressConn:Disconnect() end
return
end
local elapsed = tick() - stealStartTime
local prog = math.clamp(elapsed / AutoStealValues.STEAL_DURATION, 0, 1)
if ProgressBarFill then ProgressBarFill.Size = UDim2.new(prog, 0, 1, 0) end
if ProgressPercentLabel then ProgressPercentLabel.Text = math.floor(prog * 100) .. "%" end
if prog >= 1 then
pcall(function() prompt:InputHoldBegin() end)
task.wait(0.05)
pcall(function() prompt:InputHoldEnd() end)
if progressConn then progressConn:Disconnect() end
resetProgressBar()
isStealing = false
end
end)
end

local function startAutoSteal()
if autoStealConn then return end
autoStealConn = RunService.Heartbeat:Connect(function()
if not scriptActive or not Features.AutoSteal or isStealing then return end
local p = findNearestPrompt()
if p then executeSteal(p) end
end)
end
local function stopAutoSteal()
if autoStealConn then autoStealConn:Disconnect(); autoStealConn = nil end
if progressConn then progressConn:Disconnect(); progressConn = nil end
isStealing = false
resetProgressBar()
end

