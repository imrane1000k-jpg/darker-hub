-- ─── ANTI-RAGDOLL (OPTIMIZED) ──────────────────
local antiRagdollMode, ragdollConnections, cachedCharData = nil, {}, {}
local BOOST_SPEED, AR_DEFAULT_SPEED = 400, 16

local function arCacheCharacterData()
    local char = Player.Character
    if not char then return false end
    local hum, root = char:FindFirstChildOfClass("Humanoid"), char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return false end
    cachedCharData = { character = char, humanoid = hum, root = root }
    return true
end

local function arIsRagdolled()
    if not cachedCharData.humanoid then return false end
    local state = cachedCharData.humanoid:GetState()
    local ragdollStates = {
        [Enum.HumanoidStateType.Physics] = true,
        [Enum.HumanoidStateType.Ragdoll] = true,
        [Enum.HumanoidStateType.FallingDown] = true
    }
    if ragdollStates[state] then return true end
    local endTime = Player:GetAttribute("RagdollEndTime")
    return endTime and (endTime - workspace:GetServerTimeNow()) > 0
end

local function startAntiRagdoll()
    if antiRagdollMode then return end
    if not arCacheCharacterData() then return end
    antiRagdollMode = "v2"

    -- Camera fix
    local camConn = RunService.RenderStepped:Connect(function()
        if cachedCharData.humanoid then
            workspace.CurrentCamera.CameraSubject = cachedCharData.humanoid
        end
    end)
    table.insert(ragdollConnections, camConn)

    -- Main loop
    task.spawn(function()
        while antiRagdollMode do
            task.wait()
            if arIsRagdolled() then
                -- Force exit ragdoll
                pcall(function() Player:SetAttribute("RagdollEndTime", workspace:GetServerTimeNow()) end)
                for _, descendant in ipairs(cachedCharData.character:GetDescendants()) do
                    if descendant:IsA("BallSocketConstraint") or 
                       (descendant:IsA("Attachment") and descendant.Name:find("Ragdoll")) then
                        descendant:Destroy()
                    end
                end
                cachedCharData.humanoid:ChangeState(Enum.HumanoidStateType.Running)
                cachedCharData.root.Anchored = false
            end
        end
    end)
end

local function stopAntiRagdoll()
    antiRagdollMode = nil
    for _, conn in ipairs(ragdollConnections) do
        pcall(function() conn:Disconnect() end)
    end
    ragdollConnections = {}
    cachedCharData = {}
end

