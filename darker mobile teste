-- Exact Drop Logic (Keybind X)
local function runDrop()
    local char = Player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hum and hrp then
        hum.Jump = true
        task.wait(0.1)
        hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, -50, hrp.AssemblyLinearVelocity.Z)
    end
end

-- Path Movement (Velocity based)
local pathActive = false
local function runStealPath(path)
    pathActive = true
    local hrp = Player.Character:WaitForChild("HumanoidRootPart")
    for i, point in ipairs(path) do
        if not pathActive then break end
        local speed = (i > 2 and 29 or 57)
        while pathActive and (Vector3.new(point.pos.X, hrp.Position.Y, point.pos.Z) - hrp.Position).Magnitude > 1.5 do
            local dir = (Vector3.new(point.pos.X, hrp.Position.Y, point.pos.Z) - hrp.Position).Unit
            hrp.AssemblyLinearVelocity = Vector3.new(dir.X * speed, hrp.AssemblyLinearVelocity.Y, dir.Z * speed)
            RunService.Heartbeat:Wait()
        end
        if i == 2 then task.wait(1) end
    end
    pathActive = false
    hrp.AssemblyLinearVelocity = Vector3.zero
end

-- Front Lock (Targeting)
RunService.RenderStepped:Connect(function()
    if not Features.FrontLock or not Player.Character then return end
    local root = Player.Character:FindFirstChild("HumanoidRootPart")
    local nearest, minDist = nil, 400
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (root.Position - p.Character.HumanoidRootPart.Position).Magnitude
            if d < minDist then minDist = d; nearest = p.Character.HumanoidRootPart end
        end
    end
    if nearest then
        local spot = nearest.Position + (nearest.CFrame.LookVector * 3.5)
        local dir = (spot - root.Position)
        if dir.Magnitude > 1.5 then
            root.Velocity = Vector3.new(dir.Unit.X * 59, root.Velocity.Y, dir.Unit.Z * 59)
        end
    end
end)

