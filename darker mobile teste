local SlapList = { "Bat", "Slap", "Iron Slap", "Gold Slap", "Diamond Slap", "Emerald Slap", "Ruby Slap", "Dark Matter Slap", "Flame Slap", "Nuclear Slap", "Galaxy Slap", "Glitched Slap" }
local frontLockTarget = nil
local frontLockOriginalSpeed = 16
local batActivatedInLock = false

local function findBat()
local c = Player.Character
if not c then return nil end
local bp = Player:FindFirstChildOfClass("Backpack")
for _, ch in ipairs(c:GetChildren()) do if ch:IsA("Tool") and (ch.Name:lower():find("bat") or table.find(SlapList, ch.Name)) then return ch end end
if bp then for _, ch in ipairs(bp:GetChildren()) do if ch:IsA("Tool") and (ch.Name:lower():find("bat") or table.find(SlapList, ch.Name)) then return ch end end end
return nil
end

local function findNearestPlayerForFrontLock()
local nearestDist = math.huge
local nearestPlayer = nil
local char = Player.Character
if not char then return nil end
local root = char:FindFirstChild("HumanoidRootPart")
if not root then return nil end
local myPos = root.Position
for _, otherPlayer in ipairs(Players:GetPlayers()) do
if otherPlayer ~= Player and otherPlayer.Character then
local targetRoot = otherPlayer.Character:FindFirstChild("HumanoidRootPart")
if targetRoot then
local distance = (myPos - targetRoot.Position).Magnitude
if distance < nearestDist and distance <= FrontLockConfig.DETECTION_RADIUS then
nearestDist = distance
nearestPlayer = otherPlayer
end
end
end
end
return nearestPlayer
end

local function activateBatOnce()
if batActivatedInLock then return end
local bat = findBat()
if bat then
if bat.Parent ~= Player.Character then bat.Parent = Player.Character end
bat:Activate()
batActivatedInLock = true
end
end

