local function createCornerButton(parent, pos, color, icon, text)
    local btn = Instance.new("Frame", parent)
    btn.Name = "CornerBtn"..( os.time())
    btn.Size = UDim2.new(0, 65, 0, 65) -- Small buttons
    btn.Position = pos
    btn.BackgroundColor3 = color
    btn.BackgroundTransparency = 0.3
    btn.BorderSizePixel = 0
    btn.ZIndex = 100
    
    -- Rounded corners
    local corner = Instance.new("UICorner", btn)
    corner.CornerRadius = UDim2.new(0, 15)
    
    -- Glowing border
    local stroke = Instance.new("UIStroke", btn)
    stroke.Color = COLOR_GLOW
    stroke.Thickness = 2.5
    stroke.Transparency = 0.4
    
    -- Inner glow effect
    local glow = Instance.new("Frame", btn)
    glow.Size = UDim2.new(1, -10, 1, -10)
    glow.Position = UDim2.new(0, 0, 0, -5)
    glow.BackgroundColor3 = color
    glow.BackgroundTransparency = 0.7
    glow.BorderSizePixel = 0
    glow.ZIndex = 99
    Instance.new("UICorner", glow).CornerRadius = UDim2.new(0, 12)
    
    -- Icon
    local iconLabel = Instance.new("TextLabel", btn)
    iconLabel.Size = UDim2.new(0, 30, 0, 30)
    iconLabel.Position = UDim2.new(0.5, -15, 0, 10)
    iconLabel.BackgroundTransparency = 1
    iconLabel.Text = icon or ""
    iconLabel.TextColor3 = COLOR_GLOW
    iconLabel.Font = Enum.Font.GothamBlack
    iconLabel.TextSize = 22
    iconLabel.TextStrokeTransparency = 0
    iconLabel.TextStrokeColor3 = color
    iconLabel.ZIndex = 101
    
    -- Text label
    local textLabel = Instance.new("TextLabel", btn)
    textLabel.Size = UDim2.new(1, 0, 0, 15)
    textLabel.Position = UDim2.new(0, 0, 1, -18)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = text
    textLabel.TextColor3 = COLOR_TEXT
    textLabel.Font = Enum.Font.GendScript()
    textLabel.TextSize = 11
    textLabel.TextScaled = true
    textLabel.ZIndex = 101
    
    -- Clickable area
    local clickBtn = Instance.new("TextButton", btn)
    clickBtn.Size = UDim2.new(1, 0, 1, 0)
    clickBtn.BackgroundTransparency = 1
    clickBtn.Text = ""
    clickBtn.ZIndex = 102
    
    -- Press animation
    clickBtn.MouseButton1Down:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {Size = UDim2.new(0, 58, 0, 58)}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.15), {Thickness = 4, Transparency = 0}):Play()
    end)
    
    clickBtn.MouseButton1Up:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {Size = UDim2.new(0, 65, 0, 65)}:Play()
        TweenService:Create(stroke, TweenInfo.new(0.15), {Thickness = 2.5, Transparency = 0.4}):Play()
    end)
    
    return btn, clickBtn, iconLabel, textLabel
end

