                TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(80, 30, 140)}):Play()
                TweenService:Create(dot, TweenInfo.new(0.15), {BackgroundColor3 = COLOR_GLOW}):Play()
                btn.TextColor3 = COLOR_TEXT
            else
                TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(12, 12, 35)}):Play()
                TweenService:Create(dot, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(60, 60, 60)}):Play()
                btn.TextColor3 = COLOR_GLOW
            end
        end
        if isT and fk then
            MobileGridButtons[fk] = {Button = btn, Update = ugv}
            if Features[fk] then task.spawn(function() ugv(true) end) end
            btn.MouseButton1Click:Connect(function()
                if not scriptActive then return end
                local ns = not Features[fk]
                if fk == "AutoRight" and ns then Features.AutoLeft=false;stopStealPath();if _G["UpdateVisual_AutoLeft"]then _G["UpdateVisual_AutoLeft"](false)end end
                if fk == "AutoLeft" and ns then Features.AutoRight=false;stopStealPath();if _G["UpdateVisual_AutoRight"]then _G["UpdateVisual_AutoRight"](false)end end
                Features[fk] = ns
                if fk=="Float" then if ns then startFloat()else stopFloat()end
                elseif fk=="Helicopter" then if ns then startHelicopter()else stopHelicopter()end
                elseif fk=="FrontLock" then if ns then startFrontLock()else stopFrontLock()end
                elseif fk=="AutoRight" then if ns then startStealPath(stealPath1)else stopStealPath()end
                elseif fk=="AutoLeft" then if ns then startStealPath(stealPath2)else stopStealPath()end end
                end
                if _G["UpdateVisual_"..fk] then _G["UpdateVisual_"..fk](ns) end
            end)
        else
            btn.MouseButton1Click:Connect(function()
                if not scriptActive then return end; performDrop()
                TweenService:Create(btn, TweenInfo.new(0.08), {BackgroundColor3 = COLOR_GLOW}):Play()
                task.wait(0.12)
                TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = Color3.fromRGB(12, 12, 35)}):Play()
            end)
        end
        btn.Parent = ip
    end

    cgb("Heli", "Helicopter", true, 1)
    cgb("Float", "Float", true, 2)
    cgb("Drop", nil, false, 3)
    cgb("Lock", "FrontLock", true, 4)
    cgb("AutoR", "AutoRight", true, 5)
    cgb("AutoL", "AutoLeft", true, 6)
end
