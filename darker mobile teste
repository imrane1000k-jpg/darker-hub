end
local function findNearestPrompt()
    local h = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart"); if not h then return nil, nil, nil end
    local plots = workspace:FindFirstChild("Plots"); if not plots then return nil, nil, nil end
    local np, nd, nn = nil, math.huge, nil
    for _, plot in ipairs(plots:GetChildren()) do
        if isMyPlotByName(plot.Name) then continue end
        local podiums = plot:FindFirstChild("AnimalPodiums"); if not podiums then continue end
        for _, pod in ipairs(podiums:GetChildren()) do
            pcall(function()
                local base = pod:FindFirstChild("Base"); local spawn = base and base:FindFirstChild("Spawn")
                if spawn then
                    local dist = (spawn.Position - h.Position).Magnitude
                    if dist < nd and dist <= AutoStealValues.STEAL_RADIUS then
                        local att = spawn:FindFirstChild("PromptAttachment")
                        if att then for _, ch in ipairs(att:GetChildren()) do if ch:IsA("ProximityPrompt") then np, nd, nn = ch, dist, pod.Name; break end end end
                    end
                end
            end)
        end
    end
    return np, nd, nn
end
local function executeSteal(prompt, name)
    if isStealing then return end
    if not StealData[prompt] then
        StealData[prompt] = {hold = {}, trigger = {}, ready = true}
        pcall(function()
            if getconnections then
                for _, c in ipairs(getconnections(prompt.PromptButtonHoldBegan)) do if c.Function then table.insert(StealData[prompt].hold, c.Function) end end
                for _, c in ipairs(getconnections(prompt.Triggered)) do if c.Function then table.insert(StealData[prompt].trigger, c.Function) end end
            end
        end)
    end
    local data = StealData[prompt]
    if not data.ready then return end
    data.ready = false; isStealing = true; stealStartTime = tick()
    if ProgressLabel then ProgressLabel.Text = name or "STEALING..." end
    if progressConn then progressConn:Disconnect() end
    progressConn = RunService.Heartbeat:Connect(function()
        if not isStealing or not scriptActive then if progressConn then progressConn:Disconnect() end; return end
        local elapsed = tick() - stealStartTime; local duration = AutoStealValues.STEAL_DURATION
        local prog = math.clamp(elapsed / duration, 0, 1)
        if ProgressBarFill then ProgressBarFill.Size = UDim2.new(prog, 0, 1, 0) end
        if ProgressPercentLabel then ProgressPercentLabel.Text = math.floor(prog * 100) .. "%" end
        if prog >= 1 then
            if prompt.Parent and prompt:IsA("ProximityPrompt") then
                prompt.HoldDuration = 0.01
                pcall(function() prompt:InputHoldBegin() end)
                for _, f in ipairs(data.trigger) do pcall(f) end
                pcall(function() prompt:InputHoldEnd() end)
            end
            if progressConn then progressConn:Disconnect() end
            resetProgressBar(); data.ready = true; isStealing = false; task.wait(0.01)
            while pathActive and scriptActive do
                local p, _, n = findNearestPrompt()
                if p then executeSteal(p, n); break else RunService.Heartbeat:Wait(); if not pathActive or isPlayerRagdolled() then break end end
            end
            return
        end
        if not prompt.Parent or not prompt:IsA("ProximityPrompt") then
            if progressConn then progressConn:Disconnect() end; resetProgressBar(); data.ready = true; isStealing = false; return
        end
        pcall(function() prompt:InputHoldBegin() end)
    end)
end
