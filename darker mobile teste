local optimizerConn = nil
local optimizerSlowSweep = nil
local optimizedCache = setmetatable({}, {__mode = "kv"})
local optimizationCount = 0

local function stripObject(obj)
    if optimizedCache[obj] then return end
    optimizedCache[obj] = true
    optimizationCount = optimizationCount + 1
    
    pcall(function()
        -- 🔥 DESTROY ALL VFX EFFECTS (FPS killers)
        if obj:IsA("ParticleEmitter") or 
           obj:IsA("Trail") or 
           obj:IsA("Beam") or 
           obj:IsA("Fire") or 
           obj:IsA("Smoke") or 
           obj:IsA("Sparkles") then
            obj:Destroy()
            return
        end
        
        -- 💡 Remove lights (except on player)
        if obj:IsA("PointLight") or 
           obj:IsA("SpotLight") or 
           obj:IsA("SurfaceLight") then
            if not obj:IsDescendantOf(Player.Character) then 
                obj:Destroy() 
            end
            return
        end
        
        -- 🎨 Destroy decals and surface textures
        if obj:IsA("Decal") or obj:IsA("Texture") then
            obj:Destroy()
            return
        end
        
        -- 🧱 Handle BaseParts - REMOVE TEXTURES ONLY (keep colors!)
        if obj:IsA("BasePart") then
            -- Disable shadows (FPS boost)
            obj.CastShadow = false
            obj.ReceiveShadow = false
            
            -- MeshPart: Clear texture ID but KEEP COLOR
            if obj:IsA("MeshPart") then
                if obj.TextureID ~= "" then
                    obj.TextureID = ""  -- Remove texture only
                end
            end
            
            -- Clear child decals/textures on this part
            for _, child in ipairs(obj:GetChildren()) do
                if child:IsA("Decal") or child:IsA("Texture") then
                    optimizedCache[child] = true
                    child:Destroy()
                end
            end
            
            -- Remove unnecessary SurfaceGuis
            for _, child in ipairs(obj:GetChildren()) do
                if child:IsA("SurfaceGui") and not obj:IsDescendantOf(Player.Character) then
                    local n = child.Name:lower()
                    if not (n:find("yourbase") or n:find("plot") or n:find("name") or n:find("owner")) then
                        optimizedCache[child] = true
                        child:Destroy()
                    end
                end
            end
        end
        
        -- Clean up BillboardGuis (remove clutter)
        if obj:IsA("BillboardGui") and not obj:IsDescendantOf(Player.Character) then
            local n = obj.Name:lower()
            if n:find("timer") or n:find("speed") or n:find("ragdoll") then 
                return 
            end
            if n:find("yourbase") or n:find("plot") or n:find("name") or n:find("owner") then 
                return 
            end
            obj:Destroy()
        end
        
        -- Mute distant sounds
        if obj:IsA("Sound") and not obj:IsDescendantOf(Player.Character) then
            obj.Volume = 0
        end
        
        -- Remove post-processing effects
        if obj:IsA("BloomEffect") or 
           obj:IsA("BlurEffect") or 
           obj:IsA("ColorCorrectionEffect") or
           obj:IsA("SunRaysEffect") or
           obj:IsA("DepthOfFieldEffect") then
            obj:Destroy()
        end
    end)
end

local function sweepWorkspace()
    pcall(function()
        local descendants = workspace:GetDescendants()
        for i = 1, #descendants do
            stripObject(descendants[i])
            
            -- Yield every 1000 objects to prevent timeout
            if i % 1000 == 0 then
                task.wait()
            end
        end
    end)
end

local function enableOptimizer()
    if getgenv and getgenv().OPTIMIZER_ACTIVE then return end
    if getgenv then getgenv().OPTIMIZER_ACTIVE = true end

    -- ⚡ OPTIMIZED RENDERING SETTINGS (keep natural look)
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        settings().Rendering.MeshPartDetailLevel = Enum.MeshPartDetailLevel.Level01
        
        pcall(function() 
            settings().Rendering.TextureQuality = Enum.TextureQuality.Level01 
        end)
        
        pcall(function() settings().Rendering.EmissiveStrength = 0 end)
        
        -- Lighting optimizations (keep it looking natural)
        local Lighting = game:GetService("Lighting")
        
        -- Softer shadows instead of removing completely
        Lighting.GlobalShadows = false  -- Off for max FPS
        
        -- Bright but natural lighting
        Lighting.Brightness = 2.5
        Lighting.EnvironmentBrightness = 0.8
        
        -- Extended view distance
        Lighting.FogEnd = 999999
        
        -- Soft ambient light
        Lighting.Ambient = Color3.fromRGB(180, 180, 180)
        Lighting.OutdoorAmbient = Color3.fromRGB(180, 180, 180)
        
        -- Reduce expensive calculations
        Lighting.EnvironmentDiffuseScale = 0.5
        Lighting.EnvironmentSpecularScale = 0.3
        Lighting.ClockTime = 14
        
        -- Use compatible technology
        pcall(function()
            Lighting.Technology = Enum.Technology.Compatibility
        end)
    end)

    print("[DarkerHub] Starting Natural Optimization...")
    
    -- Initial sweep
    sweepWorkspace()
    
    print("[DarkerHub] ✓ Optimization complete! Processed " .. optimizationCount .. " objects")

    -- Real-time listener
    if optimizerConn then optimizerConn:Disconnect() end
    optimizerConn = workspace.DescendantAdded:Connect(function(obj)
        if not scriptActive or not Features.Optimizer then return end
        stripObject(obj)
    end)

    -- Safety sweep every 10 seconds
    if optimizerSlowSweep then 
        pcall(function() task.cancel(optimizerSlowSweep) end) 
    end
    optimizerSlowSweep = task.spawn(function()
        while scriptActive and Features.Optimizer do
            task.wait(10)
            if not scriptActive or not Features.Optimizer then break end
            sweepWorkspace()
        end
    end)
    
    print("[DarkerHub] ✓ Natural NoTex Optimizer ENABLED!")
end

local function disableOptimizer()
    if getgenv then getgenv().OPTIMIZER_ACTIVE = false end
    if optimizerConn then 
        optimizerConn:Disconnect() 
        optimizerConn = nil 
    end
    if optimizerSlowSweep then 
        pcall(function() task.cancel(optimizerSlowSweep) end)
        optimizerSlowSweep = nil 
    end
    print("[DarkerHub] Optimizer DISABLED")
end

