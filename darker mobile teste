    local dragging = false
    local function uvs(v)
        local r = math.clamp((v - minVal) / (maxVal - minVal), 0, 1)
        if valueKey == "STEAL_DURATION" or valueKey == "PATH_TURN_WAIT" then vl.Text = string.format("%.2f", v) .. "s" else vl.Text = tostring(v) end
        sf.Size = UDim2.new(r, 0, 1, 0); th.Position = UDim2.new(r, -4 * guiScale, 0.5, -4 * guiScale)
        if onChange then onChange(v) end
    end
    SliderReferences[valueKey] = { func = uvs }
    local function us(ir)
        ir = math.clamp(ir, 0, 1)
        if valueKey == "STEAL_DURATION" or valueKey == "PATH_TURN_WAIT" then
            local dv = tonumber(string.format("%.2f", minVal + (maxVal - minVal) * ir)); if AutoStealValues[valueKey] then AutoStealValues[valueKey] = dv end; uvs(dv); SaveConfig(); return
        end
        local v = math.floor(minVal + (maxVal - minVal) * ir)
        if Values[valueKey] then Values[valueKey] = v elseif AutoStealValues[valueKey] then AutoStealValues[valueKey] = v end; uvs(v); SaveConfig()
    end
    sb.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = true end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = false end end)
    UserInputService.InputChanged:Connect(function(i) if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then us((i.Position.X - sb.AbsolutePosition.X) / sb.AbsoluteSize.X) end end)
    local cv = Values[valueKey] or AutoStealValues[valueKey]; if cv then uvs(cv) end
    return c
end

