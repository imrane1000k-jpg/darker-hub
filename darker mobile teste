end
batActivatedInLock = false
end

local function stopFrontLock()
local char = Player.Character
if char then
local hum = char:FindFirstChildOfClass("Humanoid")
local root = char:FindFirstChild("HumanoidRootPart")
if hum then hum.WalkSpeed = frontLockOriginalSpeed end
if root then
root.Velocity = Vector3.new(0, 0, 0)
if hum then hum:MoveTo(root.Position) end
end
end
frontLockTarget = nil
batActivatedInLock = false
end

RunService.RenderStepped:Connect(function()
if not Features.FrontLock then batActivatedInLock = false return end
local char = Player.Character
if not char then return end
local hum = char:FindFirstChildOfClass("Humanoid")
local root = char:FindFirstChild("HumanoidRootPart")
if not hum or not root then return end
if hum.WalkSpeed ~= FrontLockConfig.SPEED then hum.WalkSpeed = FrontLockConfig.SPEED end
if not frontLockTarget or not frontLockTarget.Character or not frontLockTarget.Character:FindFirstChild("HumanoidRootPart") then
frontLockTarget = findNearestPlayerForFrontLock()
batActivatedInLock = false
end
if frontLockTarget and frontLockTarget.Character then
local targetRoot = frontLockTarget.Character:FindFirstChild("HumanoidRootPart")
if targetRoot then
activateBatOnce()
local targetPos = targetRoot.Position
local myPos = root.Position
local targetCFrame = targetRoot.CFrame
local lookVector = targetCFrame.LookVector
local spotInFront = targetPos + (lookVector * FrontLockConfig.FRONT_DISTANCE)
local directionVector = spotInFront - myPos
local distance = directionVector.Magnitude
local heightDiff = targetPos.Y - myPos.Y
local horizontalDir = Vector3.new(directionVector.X, 0, directionVector.Z).Unit
if horizontalDir.Magnitude == 0 then horizontalDir = Vector3.new(1,0,0) end
local verticalVel = 0
if math.abs(heightDiff) > 2 then
verticalVel = (heightDiff > 0 and FrontLockConfig.SPEED * 0.8) or (-FrontLockConfig.SPEED * 0.8)
end
if distance > FrontLockConfig.STOP_DISTANCE then
root.Velocity = Vector3.new(horizontalDir.X * FrontLockConfig.SPEED, verticalVel, horizontalDir.Z * FrontLockConfig.SPEED)
hum:MoveTo(spotInFront)
else
root.Velocity = Vector3.new(0, 0, 0)
hum:MoveTo(myPos)
end
else
frontLockTarget = nil
batActivatedInLock = false
end
else
frontLockTarget = nil
batActivatedInLock = false
end
end)

Player.CharacterAdded:Connect(function(newChar)
