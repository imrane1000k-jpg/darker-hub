local function createCubeButton(parent, labelText, featureKey, defaultColor, activeColor)
local btn = Instance.new("TextButton")
btn.Size = UDim2.new(0, 70 * guiScale, 0, 70 * guiScale)
btn.BackgroundColor3 = defaultColor
btn.Text = labelText
btn.TextColor3 = COLOR_TEXT
btn.Font = Enum.Font.GothamBlack
btn.TextSize = 12 * guiScale
btn.TextWrapped = true
btn.BorderSizePixel = 0
btn.ZIndex = 55
btn.Parent = parent

local btnCorner = Instance.new("UICorner", btn)
btnCorner.CornerRadius = UDim.new(0, 12 * guiScale)

local btnStroke = Instance.new("UIStroke", btn)
btnStroke.Color = COLOR_GLOW
btnStroke.Thickness = 2 * guiScale
btnStroke.Transparency = 0.2

local isActive = false

btn.MouseButton1Click:Connect(function()
if featureKey == "AutoRight" then
isActive = not isActive
if isActive then
if Features.AutoLeft then
Features.AutoLeft = false
if _G["UpdateVisual_AutoLeft"] then _G["UpdateVisual_AutoLeft"](false) end
for _, child in ipairs(cubeBox:GetChildren()) do
if child:IsA("TextButton") and child.Text == "AUTO L" then
child.BackgroundColor3 = COLOR_ACCENT
end
end
end
Features.AutoRight = true
if _G["UpdateVisual_AutoRight"] then _G["UpdateVisual_AutoRight"](true) end
stopStealPath()
startStealPath(stealPath1)
btn.BackgroundColor3 = activeColor
btn.TextColor3 = COLOR_BG_MAIN
btnStroke.Transparency = 0
else
Features.AutoRight = false
if _G["UpdateVisual_AutoRight"] then _G["UpdateVisual_AutoRight"](false) end
stopStealPath()
btn.BackgroundColor3 = defaultColor
btn.TextColor3 = COLOR_TEXT
btnStroke.Transparency = 0.2
end
elseif featureKey == "AutoLeft" then
isActive = not isActive
if isActive then
if Features.AutoRight then
Features.AutoRight = false
if _G["UpdateVisual_AutoRight"] then _G["UpdateVisual_AutoRight"](false) end
for _, child in ipairs(cubeBox:GetChildren()) do
if child:IsA("TextButton") and child.Text == "AUTO R" then
child.BackgroundColor3 = COLOR_ACCENT
end
end
end
Features.AutoLeft = true
if _G["UpdateVisual_AutoLeft"] then _G["UpdateVisual_AutoLeft"](true) end
stopStealPath()
startStealPath(stealPath2)
btn.BackgroundColor3 = activeColor
btn.TextColor3 = COLOR_BG_MAIN
btnStroke.Transparency = 0
else
Features.AutoLeft = false
if _G["UpdateVisual_AutoLeft"] then _G["UpdateVisual_AutoLeft"](false) end
stopStealPath()
btn.BackgroundColor3 = defaultColor
btn.TextColor3 = COLOR_TEXT
btnStroke.Transparency = 0.2
end
elseif featureKey == "DropShot" then
performDrop()
local oldColor = btn.BackgroundColor3
btn.BackgroundColor3 = COLOR_GLOW
task.wait(0.1)
btn.BackgroundColor3 = oldColor
elseif featureKey == "FrontLock" then
isActive = not isActive
Features.FrontLock = isActive
if _G["UpdateVisual_FrontLock"] then _G["UpdateVisual_FrontLock"](isActive) end
if isActive then
startFrontLock()
btn.BackgroundColor3 = activeColor
btn.TextColor3 = COLOR_BG_MAIN
btnStroke.Transparency = 0
else
stopFrontLock()
btn.BackgroundColor3 = defaultColor
btn.TextColor3 = COLOR_TEXT
btnStroke.Transparency = 0.2
end
end
end)

return btn
end

if isMobile then
-- Create 2x2 grid: Top-Left: Auto R, Top-Right: Auto L, Bottom-Left: Drop, Bottom-Right: Front Lock
createCubeButton(cubeBox, "AUTO R", "AutoRight", COLOR_ACCENT, COLOR_GLOW)
createCubeButton(cubeBox, "AUTO L", "AutoLeft", COLOR_ACCENT, COLOR_GLOW)
createCubeButton(cubeBox, "DROP", "DropShot", COLOR_DROP, COLOR_GLOW)
createCubeButton(cubeBox, "FRONT\nLOCK", "FrontLock", COLOR_FRONT_LOCK, COLOR_GLOW)
end

