-- 9. Front Lock + Bat
local SlapList = { "Bat", "Slap", "Iron Slap", "Gold Slap", "Diamond Slap", "Emerald Slap", "Ruby Slap", "Dark Matter Slap", "Flame Slap", "Nuclear Slap", "Galaxy Slap", "Glitched Slap" }
local frontLockTarget = nil
local frontLockOriginalSpeed = 16
local batActivatedInLock = false

local function findBat()
local c = Player.Character
if not c then return nil end
local bp = Player:FindFirstChildOfClass("Backpack")
for _, ch in ipairs(c:GetChildren()) do if ch:IsA("Tool") and (ch.Name:lower():find("bat") or table.find(SlapList, ch.Name)) then return ch end end
if bp then for _, ch in ipairs(bp:GetChildren()) do if ch:IsA("Tool") and (ch.Name:lower():find("bat") or table.find(SlapList, ch.Name)) then return ch end end end
return nil
end

local function findNearestPlayerForFrontLock()
local nearestDist = math.huge
local nearestPlayer = nil
local char = Player.Character
if not char then return nil end
local root = char:FindFirstChild("HumanoidRootPart")
if not root then return nil end
local myPos = root.Position
for _, otherPlayer in ipairs(Players:GetPlayers()) do
if otherPlayer ~= Player and otherPlayer.Character then
local targetRoot = otherPlayer.Character:FindFirstChild("HumanoidRootPart")
if targetRoot then
local distance = (myPos - targetRoot.Position).Magnitude
if distance < nearestDist and distance <= FrontLockConfig.DETECTION_RADIUS then
nearestDist = distance
nearestPlayer = otherPlayer
end
end
end
end
return nearestPlayer
end

local function activateBatOnce()
if batActivatedInLock then return end
local bat = findBat()
if bat then
if bat.Parent ~= Player.Character then bat.Parent = Player.Character end
bat:Activate()
batActivatedInLock = true
end
end

local function startFrontLock()
local char = Player.Character
if char then
local hum = char:FindFirstChildOfClass("Humanoid")
if hum then frontLockOriginalSpeed = hum.WalkSpeed end
end
batActivatedInLock = false
end

local function stopFrontLock()
local char = Player.Character
if char then
local hum = char:FindFirstChildOfClass("Humanoid")
local root = char:FindFirstChild("HumanoidRootPart")
if hum then hum.WalkSpeed = frontLockOriginalSpeed end
if root then
root.Velocity = Vector3.new(0, 0, 0)
if hum then hum:MoveTo(root.Position) end
end
end
frontLockTarget = nil
batActivatedInLock = false
end

RunService.RenderStepped:Connect(function()
if not Features.FrontLock then batActivatedInLock = false return end
local char = Player.Character
if not char then return end
local hum = char:FindFirstChildOfClass("Humanoid")
local root = char:FindFirstChild("HumanoidRootPart")
if not hum or not root then return end
if hum.WalkSpeed ~= FrontLockConfig.SPEED then hum.WalkSpeed = FrontLockConfig.SPEED end
if not frontLockTarget or not frontLockTarget.Character or not frontLockTarget.Character:FindFirstChild("HumanoidRootPart") then
frontLockTarget = findNearestPlayerForFrontLock()
batActivatedInLock = false
end
if frontLockTarget and frontLockTarget.Character then
local targetRoot = frontLockTarget.Character:FindFirstChild("HumanoidRootPart")
if targetRoot then
activateBatOnce()
local targetPos = targetRoot.Position
local myPos = root.Position
local targetCFrame = targetRoot.CFrame
local lookVector = targetCFrame.LookVector
local spotInFront = targetPos + (lookVector * FrontLockConfig.FRONT_DISTANCE)
local directionVector = spotInFront - myPos
local distance = directionVector.Magnitude
local heightDiff = targetPos.Y - myPos.Y
local horizontalDir = Vector3.new(directionVector.X, 0, directionVector.Z).Unit
if horizontalDir.Magnitude == 0 then horizontalDir = Vector3.new(1,0,0) end
local verticalVel = 0
if math.abs(heightDiff) > 2 then
verticalVel = (heightDiff > 0 and FrontLockConfig.SPEED * 0.8) or (-FrontLockConfig.SPEED * 0.8)
end
if distance > FrontLockConfig.STOP_DISTANCE then
root.Velocity = Vector3.new(horizontalDir.X * FrontLockConfig.SPEED, verticalVel, horizontalDir.Z * FrontLockConfig.SPEED)
hum:MoveTo(spotInFront)
else
root.Velocity = Vector3.new(0, 0, 0)
hum:MoveTo(myPos)
end
else
frontLockTarget = nil
batActivatedInLock = false
end
else
frontLockTarget = nil
batActivatedInLock = false
end
end)

Player.CharacterAdded:Connect(function(newChar)
if Features.FrontLock then
task.wait(0.05)
local hum = newChar:FindFirstChildOfClass("Humanoid")
if hum then hum.WalkSpeed = FrontLockConfig.SPEED end
frontLockTarget = nil
batActivatedInLock = false
end
end)

