local function createSlider(parent, labelText, minVal, maxVal, valueKey, onChange)
local container = Instance.new("Frame", parent)
container.Size = UDim2.new(1, -8 * guiScale, 0, 40 * guiScale)
container.BackgroundColor3 = COLOR_BG_ROW
container.BackgroundTransparency = 0.4
container.BorderSizePixel = 0
container.LayoutOrder = toggleSliderOrder
toggleSliderOrder = toggleSliderOrder + 1
Instance.new("UICorner", container).CornerRadius = UDim.new(0, 6 * guiScale)

local label = Instance.new("TextLabel", container)
label.Size = UDim2.new(1, 0, 0, 14 * guiScale)
label.BackgroundTransparency = 1
label.Text = labelText
label.TextColor3 = COLOR_DIM
label.Font = Enum.Font.GothamBold
label.TextSize = 10 * guiScale
label.TextXAlignment = Enum.TextXAlignment.Left

local sliderBg = Instance.new("Frame", container)
sliderBg.Size = UDim2.new(1, 0, 0, 5 * guiScale)
sliderBg.Position = UDim2.new(0, 0, 0, 20 * guiScale)
sliderBg.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
Instance.new("UICorner", sliderBg).CornerRadius = UDim.new(1, 0)

local sliderFill = Instance.new("Frame", sliderBg)
sliderFill.Size = UDim2.new(0.5, 0, 1, 0)
sliderFill.BackgroundColor3 = COLOR_ACCENT
Instance.new("UICorner", sliderFill).CornerRadius = UDim.new(1, 0)

local thumb = Instance.new("Frame", sliderBg)
thumb.Size = UDim2.new(0, 10 * guiScale, 0, 10 * guiScale)
thumb.Position = UDim2.new(0.5, -5 * guiScale, 0.5, -5 * guiScale)
thumb.BackgroundColor3 = COLOR_GLOW
Instance.new("UICorner", thumb).CornerRadius = UDim.new(1, 0)

local valueLabel = Instance.new("TextLabel", container)
valueLabel.Size = UDim2.new(0, 35 * guiScale, 0, 14 * guiScale)
valueLabel.Position = UDim2.new(1, -38 * guiScale, 0, 0)
valueLabel.BackgroundTransparency = 1
valueLabel.Text = tostring(Values[valueKey] or AutoStealValues[valueKey])
valueLabel.TextColor3 = COLOR_GLOW
valueLabel.Font = Enum.Font.GothamBold
valueLabel.TextSize = 10 * guiScale

local dragging = false
local function updateSliderVisual(value)
local relative = (value - minVal) / (maxVal - minVal)
relative = math.clamp(relative, 0, 1)
valueLabel.Text = tostring(value)
sliderFill.Size = UDim2.new(relative, 0, 1, 0)
thumb.Position = UDim2.new(relative, -5 * guiScale, 0.5, -5 * guiScale)
if onChange then onChange(value) end
end

local function updateSlider(inputRelative)
inputRelative = math.clamp(inputRelative, 0, 1)
local value = math.floor(minVal + (maxVal - minVal) * inputRelative)
if Values[valueKey] then Values[valueKey] = value
elseif AutoStealValues[valueKey] then AutoStealValues[valueKey] = value end
updateSliderVisual(value)
SaveConfig()
end

sliderBg.InputBegan:Connect(function(input)
if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true end
end)
UserInputService.InputEnded:Connect(function(input)
if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
end)
UserInputService.InputChanged:Connect(function(input)
if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
local relative = (input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X
updateSlider(relative)
end
end)

local currentVal = Values[valueKey] or AutoStealValues[valueKey]
if currentVal then updateSliderVisual(currentVal) end
return container
end

