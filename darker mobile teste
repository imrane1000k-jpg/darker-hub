local dropRunning = false
local function performDrop()
    if dropRunning then return end
    dropRunning = true
    local char = Player.Character or Player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    
    if hum and hrp then
        hum.Jump = true
        task.wait(0.05)
        hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, -55, hrp.AssemblyLinearVelocity.Z)
    end
    
    task.wait(0.2)
    dropRunning = false
end

-- Path Movement
local pathActive = false
local function isPlayerRagdolled()
    local char = Player.Character
    if not char then return true end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return true end
    local state = hum:GetState()
    local ragdollStates = {[Enum.HumanoidStateType.Physics] = true, [Enum.HumanoidStateType.Ragdoll] = true, [Enum.HumanoidStateType.FallingDown] = true}
    if ragdollStates[state] then return true end
    local endTime = Player:GetAttribute("RagdollEndTime")
    if endTime and (endTime - workspace:GetServerTimeNow()) > 0 then return true end
    return false
end

local function pathMoveToPoint(hrp, current, nextPoint, speed)
    local conn
    local reached = false
    conn = RunService.Heartbeat:Connect(function()
        if not pathActive or isPlayerRagdolled() then
            if conn then conn:Disconnect() end
            hrp.AssemblyLinearVelocity = Vector3.zero
            reached = true
            return
        end
        local pos = hrp.Position
        local target = Vector3.new(current.X, pos.Y, current.Z)
        local dir = target - pos
        local dist = dir.Magnitude
        local stopDist = 1.35
        if dist <= stopDist then
            if conn then conn:Disconnect() end
            hrp.AssemblyLinearVelocity = Vector3.zero
            reached = true
            return
        end
        local moveDir = dir.Unit
        if nextPoint then
            local nextDir = (Vector3.new(nextPoint.X, pos.Y, nextPoint.Z) - pos).Unit
            moveDir = (moveDir + nextDir * 0.45).Unit
        end
        hrp.AssemblyLinearVelocity = Vector3.new(moveDir.X * speed, hrp.AssemblyLinearVelocity.Y, moveDir.Z * speed)
    end)
    while pathActive and not reached and not isPlayerRagdolled() and (Vector3.new(hrp.Position.X, 0, hrp.Position.Z) - Vector3.new(current.X, 0, current.Z)).Magnitude > 1.35 do
        RunService.Heartbeat:Wait()
    end
    if conn then conn:Disconnect() end
    hrp.AssemblyLinearVelocity = Vector3.zero
    return not isPlayerRagdolled()
end

local function runStealPath(path)
    local char = Player.Character or Player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    for i, p in ipairs(path) do
        if isPlayerRagdolled() or not pathActive then return false end
        local speed = i > 2 and 29 or 57
        local nextP = path[i + 1] and path[i + 1].pos
        if not pathMoveToPoint(hrp, p.pos, nextP, speed) then return false end
        if i == 2 then task.wait(1) else task.wait(0.01) end
        if isPlayerRagdolled() or not pathActive then return false end
    end
    return true
end

local function startStealPath(path)
    if pathActive then return end
    pathActive = true
    task.spawn(function()
        while pathActive do
            local completed = runStealPath(path)
            if not completed then
                while pathActive and isPlayerRagdolled() do RunService.Heartbeat:Wait() end
                if not pathActive then break end
            else task.wait(0.1) end
        end
    end)
end

local function stopStealPath()
    pathActive = false
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.AssemblyLinearVelocity = Vector3.zero end
end

-- Front Lock
local frontLockTarget = nil
local frontLockOriginalSpeed = 16
local function findNearestPlayerForFrontLock()
    local nearestDist = math.huge
    local nearestPlayer = nil
    local char = Player.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local myPos = root.Position
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= Player and otherPlayer.Character then
            local targetRoot = otherPlayer.Character:FindFirstChild("HumanoidRootPart")
            if targetRoot then
                local distance = (myPos - targetRoot.Position).Magnitude
                if distance < nearestDist and distance <= FrontLockConfig.DETECTION_RADIUS then
                    nearestDist = distance
                    nearestPlayer = otherPlayer
                end
            end
        end
    end
    return nearestPlayer
end

local function startFrontLock()
    frontLockOriginalSpeed = Player.Character and Player.Character:FindFirstChildOfClass("Humanoid") and Player.Character:FindFirstChildOfClass("Humanoid").WalkSpeed or 16
end

local function stopFrontLock()
    local char = Player.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")
        if hum then hum.WalkSpeed = frontLockOriginalSpeed end
        if root then
            root.Velocity = Vector3.new(0, 0, 0)
            hum:MoveTo(root.Position)
        end
    end
    frontLockTarget = nil
end

RunService.RenderStepped:Connect(function()
    if not Features.FrontLock then return end
    local char = Player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end
    hum.WalkSpeed = FrontLockConfig.SPEED
    if not frontLockTarget or not frontLockTarget.Character or not frontLockTarget.Character:FindFirstChild("HumanoidRootPart") then
        frontLockTarget = findNearestPlayerForFrontLock()
    end
    if frontLockTarget and frontLockTarget.Character then
        local targetRoot = frontLockTarget.Character:FindFirstChild("HumanoidRootPart")
        if targetRoot then
            local targetPos = targetRoot.Position
            local myPos = root.Position
            local targetCFrame = targetRoot.CFrame
            local lookVector = targetCFrame.LookVector
            local spotInFront = targetPos + (lookVector * FrontLockConfig.FRONT_DISTANCE)
            local directionVector = spotInFront - myPos
            local distance = directionVector.Magnitude
            local heightDiff = targetPos.Y - myPos.Y
            local horizontalDir = Vector3.new(directionVector.X, 0, directionVector.Z).Unit
            if horizontalDir.Magnitude == 0 then horizontalDir = Vector3.new(1,0,0) end
            local verticalVel = 0
            if math.abs(heightDiff) > 2 then
                verticalVel = (heightDiff > 0 and FrontLockConfig.SPEED * 0.8) or (-FrontLockConfig.SPEED * 0.8)
            end
            if distance > FrontLockConfig.STOP_DISTANCE then
                root.Velocity = Vector3.new(horizontalDir.X * FrontLockConfig.SPEED, verticalVel, horizontalDir.Z * FrontLockConfig.SPEED)
                hum:MoveTo(spotInFront)
            else
                root.Velocity = Vector3.new(0, 0, 0)
                hum:MoveTo(myPos)
            end
        else
            frontLockTarget = nil
        end
    else
        frontLockTarget = nil
    end
end)

