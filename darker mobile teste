-- ─── AUTO STEAL SYSTEM (ENHANCED) ──────────────
local isStealing = false
local StealData = {}
local stealCooldown = 0.1
local lastStealAttempt = 0

local function findNearestPrompt()
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil, nil, nil end
    
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil, nil, nil end
    
    local nearestPrompt, nearestDist, nearestName = nil, math.huge, nil
    for _, plot in ipairs(plots:GetChildren()) do
        if plot.Name == Player.Name.."Plot" then continue end -- Skip own plot
        
        local podiums = plot:FindFirstChild("AnimalPodiums")
        if podiums then
            for _, pod in ipairs(podiums:GetChildren()) do
                local base = pod:FindFirstChild("Base")
                local spawn = base and base:FindFirstChild("Spawn")
                if spawn then
                    local dist = (spawn.Position - hrp.Position).Magnitude
                    if dist < nearestDist and dist <= AutoStealValues.STEAL_RADIUS then
                        local att = spawn:FindFirstChild("PromptAttachment")
                        if att then
                            for _, child in ipairs(att:GetChildren()) do
                                if child:IsA("ProximityPrompt") then
                                    nearestPrompt, nearestDist, nearestName = child, dist, pod.Name
                                    break
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return nearestPrompt, nearestDist, nearestName
end

local function executeSteal(prompt, name)
    if isStealing or tick() - lastStealAttempt < stealCooldown then return end
    
    StealData[prompt] = StealData[prompt] or {ready = true}
    if not StealData[prompt].ready then return end
    
    StealData[prompt].ready = false
    isStealing = true
    lastStealAttempt = tick()
    
    -- Instant trigger bypass
    prompt.HoldDuration = 0.01
    pcall(function()
        prompt:InputHoldBegin()
        prompt:InputHoldEnd()
        fireclickdetector(prompt.Parent:FindFirstChildOfClass("ClickDetector"))
    end)
    
    task.wait(0.1)
    StealData[prompt].ready = true
    isStealing = false
end

-- ─── FRONT LOCK (PREDICTIVE) ───────────────────
local frontLockTarget = nil
local SlapList = {"Bat", "Slap", "Iron Slap", "Gold Slap", "Diamond Slap", "Emerald Slap", "Ruby Slap", "Dark Matter Slap", "Flame Slap", "Nuclear Slap", "Galaxy Slap"}

local function findBat()
    local char = Player.Character
    local bp = Player.Backpack
    if char then
        for _, tool in ipairs(char:GetChildren()) do
            if tool:IsA("Tool") and (tool.Name:lower():find("bat") or table.find(SlapList, tool.Name)) then
                return tool
            end
        end
    end
    if bp then
        for _, tool in ipairs(bp:GetChildren()) do
            if tool:IsA("Tool") and (tool.Name:lower():find("bat") or table.find(SlapList, tool.Name)) then
                return tool
            end
        end
    end
    return nil
end

local function predictTargetPosition(targetRoot, predictionTime)
    local vel = targetRoot.AssemblyLinearVelocity
    return targetRoot.Position + (vel * predictionTime)
end

local frontLockConnection = nil
local function startFrontLock()
    if frontLockConnection then return end
    
    frontLockConnection = RunService.RenderStepped:Connect(function()
        if not Features.FrontLock then return end
        
        local char = Player.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")
        if not hum or not root then return end
        
        hum.WalkSpeed = FrontLockConfig.SPEED
        
        if not frontLockTarget or not frontLockTarget.Character then
            frontLockTarget = nil
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (root.Position - p.Character.HumanoidRootPart.Position).Magnitude
                    if dist <= FrontLockConfig.DETECTION_RADIUS then
                        frontLockTarget = p
                        break
                    end
                end
            end
        end
        
        if frontLockTarget and frontLockTarget.Character then
            local targetRoot = frontLockTarget.Character:FindFirstChild("HumanoidRootPart")
            if targetRoot then
                -- Auto-equip and swing bat
                local bat = findBat()
                if bat and bat.Parent ~= char then bat.Parent = char end
                if bat then bat:Activate() end
                
                -- Predictive positioning
                local predictedPos = predictTargetPosition(targetRoot, FrontLockConfig.PREDICTION_TIME)
                local targetCFrame = targetRoot.CFrame
                local spotInFront = predictedPos + (targetCFrame.LookVector * FrontLockConfig.FRONT_DISTANCE)
                
                local direction = (spotInFront - root.Position)
                local distance = direction.Magnitude
                
                if distance > FrontLockConfig.STOP_DISTANCE then
                    local moveDir = direction.Unit
                    safeVelocitySet(root, Vector3.new(moveDir.X * FrontLockConfig.SPEED, 0, moveDir.Z * FrontLockConfig.SPEED))
                    hum:MoveTo(spotInFront)
                end
            end
        end
    end)
end

local function stopFrontLock()
    Features.FrontLock = false
    if frontLockConnection then
        frontLockConnection:Disconnect()
        frontLockConnection = nil
    end
    frontLockTarget = nil
end

-- ─── PATH STEAL SYSTEM ─────────────────────────
local pathActive = false
local PATH_VELOCITY_SPEED = 57

local function runStealPath(path)
    local char = Player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    for _, waypoint in ipairs(path) do
        if not pathActive then return end
        
        local bodyVelocity = Instance.new("BodyVelocity")
        bodyVelocity.MaxForce = Vector3.new(4000, 0, 4000)
        bodyVelocity.Velocity = Vector3.new(0, hrp.AssemblyLinearVelocity.Y, 0)
        bodyVelocity.Parent = hrp
        
        local connection
        connection = RunService.Heartbeat:Connect(function()
            if not pathActive then 
                connection:Disconnect()
                bodyVelocity:Destroy()
                return 
            end
            
            local direction = (waypoint.pos - hrp.Position)
            local flatDir = Vector3.new(direction.X, 0, direction.Z).Unit
            bodyVelocity.Velocity = flatDir * PATH_VELOCITY_SPEED
            
            if (waypoint.pos - hrp.Position).Magnitude < 2 then
                connection:Disconnect()
                bodyVelocity:Destroy()
            end
        end)
        
        repeat task.wait() until not pathActive or (waypoint.pos - hrp.Position).Magnitude < 2
    end
end

