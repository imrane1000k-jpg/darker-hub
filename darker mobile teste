local infinityJumpEnabled = false
local JUMP_BOOST_FORCE = 65

-- PC: track Space held
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.Space then spaceHeld = true end
end)
UserInputService.InputEnded:Connect(function(input, gpe)
    if input.KeyCode == Enum.KeyCode.Space then spaceHeld = false end
end)

-- Phone: track actual touch on jump button zone (bottom-right area)
local mobileJumpTouches = {}

UserInputService.TouchStarted:Connect(function(touch, gpe)
    if gpe or not isMobile then return end
    if not infinityJumpEnabled then return end
    local vp = Workspace.CurrentCamera and Workspace.CurrentCamera.ViewportSize or Vector3.new(360, 640)
    local pos = touch.Position
    -- Jump button is in bottom-right quadrant
    if pos.X > vp.X * 0.7 and pos.Y > vp.Y * 0.55 then
        mobileJumpTouches[touch] = true
        spaceHeld = true
    end
end)

UserInputService.TouchEnded:Connect(function(touch, gpe)
    if gpe or not isMobile then return end
    if mobileJumpTouches[touch] then
        mobileJumpTouches[touch] = nil
        -- Only release if NO other jump touches are active
        local anyStillHeld = false
        for _ in pairs(mobileJumpTouches) do anyStillHeld = true; break end
        if not anyStillHeld then spaceHeld = false end
    end
end)

