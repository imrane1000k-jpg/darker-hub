local Cebo = { Circle = nil, Align = nil, Attach = nil }
local frontLockTarget = nil
local frontLockOriginalSpeed = 16
local frontLockEquippedBat = false
local frontLockSmoothVelocity = Vector3.new(0, 0, 0)

local function findNearestPlayerForFrontLock()
    local nearestDist = math.huge; local nearestPlayer = nil
    local char = Player.Character; if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart"); if not root then return nil end
    local myPos = root.Position
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= Player and otherPlayer.Character then
            local targetRoot = otherPlayer.Character:FindFirstChild("HumanoidRootPart")
            if targetRoot then
                local distance = (myPos - targetRoot.Position).Magnitude
                if distance < nearestDist and distance <= FrontLockConfig.DETECTION_RADIUS then 
                    nearestDist = distance; 
                    nearestPlayer = otherPlayer 
                end
            end
        end
    end
    return nearestPlayer
end

local function startFrontLock()
    frontLockOriginalSpeed = Player.Character and Player.Character:FindFirstChildOfClass("Humanoid") and Player.Character:FindFirstChildOfClass("Humanoid").WalkSpeed or 16
    frontLockEquippedBat = false
    frontLockSmoothVelocity = Vector3.new(0, 0, 0)
    local c = Player.Character
    if c then
        local hrp = c:FindFirstChild("HumanoidRootPart")
        if hrp then
            if Cebo.Attach then Cebo.Attach:Destroy() end
            if Cebo.Align then Cebo.Align:Destroy() end
            if Cebo.Circle then Cebo.Circle:Destroy() end
            Cebo.Attach = Instance.new("Attachment", hrp)
            Cebo.Align = Instance.new("AlignOrientation", hrp)
            Cebo.Align.Attachment0 = Cebo.Attach; Cebo.Align.Mode = Enum.OrientationAlignmentMode.OneAttachment; Cebo.Align.RigidityEnabled = true
            Cebo.Circle = Instance.new("Part")
            Cebo.Circle.Shape = Enum.PartType.Cylinder; Cebo.Circle.Material = Enum.Material.Neon
            Cebo.Circle.Size = Vector3.new(0.05, 8.0, 8.0); Cebo.Circle.Color = Color3.fromRGB(0, 255, 100)
            Cebo.Circle.CanCollide = false; Cebo.Circle.Massless = true; Cebo.Circle.Parent = workspace
            local weld = Instance.new("Weld"); weld.Part0 = hrp; weld.Part1 = Cebo.Circle
            weld.C0 = CFrame.new(0, -1, 0) * CFrame.Angles(0, 0, math.rad(90)); weld.Parent = Cebo.Circle
        end
    end
end

local function stopFrontLock()
    local char = Player.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid"); local root = char:FindFirstChild("HumanoidRootPart")
        if hum then hum.WalkSpeed = frontLockOriginalSpeed; hum.AutoRotate = true end
        if root then root.Velocity = Vector3.new(0, 0, 0) end
    end
    frontLockTarget = nil; frontLockEquippedBat = false; frontLockSmoothVelocity = Vector3.new(0, 0, 0)
    if Cebo.Circle then Cebo.Circle:Destroy(); Cebo.Circle = nil end
    if Cebo.Align then Cebo.Align:Destroy(); Cebo.Align = nil end
    if Cebo.Attach then Cebo.Attach:Destroy(); Cebo.Attach = nil end
end

TrackRS(function()
    if not scriptActive or not Features.FrontLock then return end
    local char = Player.Character; if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid"); local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end
    
    if hum.WalkSpeed ~= FrontLockConfig.SPEED then 
        hum.WalkSpeed = FrontLockConfig.SPEED 
    end
    
    if not frontLockTarget or not frontLockTarget.Character or not frontLockTarget.Character:FindFirstChild("HumanoidRootPart") then
        frontLockTarget = findNearestPlayerForFrontLock()
        frontLockEquippedBat = false
    end
    
    if frontLockTarget and frontLockTarget.Character then
        local targetRoot = frontLockTarget.Character:FindFirstChild("HumanoidRootPart")
        if targetRoot then
            local targetPos = targetRoot.Position
            local myPos = root.Position
            local targetCFrame = targetRoot.CFrame
            
            local lookVector = targetCFrame.LookVector
            local spotBehind = targetPos - (lookVector * FrontLockConfig.BEHIND_DISTANCE)
            
            local directionVector = spotBehind - myPos
            local distance = directionVector.Magnitude
            
            local heightDiff = targetPos.Y - myPos.Y
            local horizontalDir = Vector3.new(directionVector.X, 0, directionVector.Z).Unit
            if horizontalDir.Magnitude == 0 then horizontalDir = Vector3.new(1,0,0) end
            
            local verticalVel = 0
            if math.abs(heightDiff) > 2 then 
                verticalVel = (heightDiff > 0 and FrontLockConfig.SPEED * 0.8) or (-FrontLockConfig.SPEED * 0.8) 
            end
            
            if distance > FrontLockConfig.STOP_DISTANCE then
                local targetVelocity = Vector3.new(
                    horizontalDir.X * FrontLockConfig.SPEED, 
                    verticalVel, 
                    horizontalDir.Z * FrontLockConfig.SPEED
                )
                
                frontLockSmoothVelocity = frontLockSmoothVelocity:Lerp(targetVelocity, 0.15)
                
                root.Velocity = frontLockSmoothVelocity
                hum:MoveTo(spotBehind)
            else
                root.Velocity = Vector3.new(0, verticalVel * 0.3, 0)
                hum:MoveTo(myPos)
                frontLockSmoothVelocity = Vector3.new(0, 0, 0)
            end
            
            char.Humanoid.AutoRotate = false
            if Cebo.Align then
                Cebo.Align.Enabled = true
                Cebo.Align.CFrame = CFrame.lookAt(myPos, Vector3.new(targetPos.X, myPos.Y, targetPos.Z))
            end
            
            if not frontLockEquippedBat then
                local backpack = Player:FindFirstChildOfClass("Backpack")
                local bat = char:FindFirstChild("Bat") or char:FindFirstChild("Medusa") or (backpack and (backpack:FindFirstChild("Bat") or backpack:FindFirstChild("Medusa")))
                if bat then 
                    if bat.Parent ~= char then bat.Parent = char end
                    frontLockEquippedBat = true 
                end
            end
        else 
            frontLockTarget = nil 
        end
    else
        frontLockTarget = nil
        frontLockEquippedBat = false
        if Cebo.Align then Cebo.Align.Enabled = false end
        if char:FindFirstChild("Humanoid") then char.Humanoid.AutoRotate = true end
    end
end)

Player.CharacterAdded:Connect(function(newChar) if Features.FrontLock then task.wait(0.05); startFrontLock() end end)

