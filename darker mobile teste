    Instance.new("UICorner", th).CornerRadius = UDim.new(1, 0)
    local vl = Instance.new("TextLabel", c); vl.Size = UDim2.new(0, 30 * guiScale, 0, 13 * guiScale); vl.Position = UDim2.new(1, -34 * guiScale, 0, 0); vl.BackgroundTransparency = 1
