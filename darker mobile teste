frontLockTarget = nil
batActivatedInLock = false
end
end)

-- 9. Path Steal Logic
local pathActive = false
local pathPaused = false
local currentPathIndex = 1
local lastFlatVel = Vector3.zero
local PATH_VELOCITY_SPEED, PATH_SECOND_SPEED = 57, 29
local PATH_BASE_STOP, PATH_MIN_STOP = 1.35, 0.65
local PATH_NEXT_POINT_BIAS, PATH_SMOOTH_FACTOR = 0.45, 0.12
local currentPathType = nil

local function isPlayerRagdolled()
local char = Player.Character
if not char then return true end
local hum = char:FindFirstChildOfClass("Humanoid")
if not hum then return true end
local state = hum:GetState()
local ragdollStates = {[Enum.HumanoidStateType.Physics] = true, [Enum.HumanoidStateType.Ragdoll] = true, [Enum.HumanoidStateType.FallingDown] = true}
if ragdollStates[state] then return true end
local endTime = Player:GetAttribute("RagdollEndTime")
if endTime and (endTime - workspace:GetServerTimeNow()) > 0 then return true end
return false
end

local function pathMoveToPoint(hrp, current, nextPoint, speed)
local conn
local reached = false
conn = RunService.Heartbeat:Connect(function()
if not pathActive then if conn then conn:Disconnect() end hrp.AssemblyLinearVelocity = Vector3.zero reached = true return end
if isPlayerRagdolled() then pathPaused = true hrp.AssemblyLinearVelocity = Vector3.zero return
else if pathPaused then pathPaused = false end end
if pathPaused then return end
local pos = hrp.Position
local target = Vector3.new(current.X, pos.Y, current.Z)
local dir = target - pos
local dist = dir.Magnitude
local stopDist = math.clamp(PATH_BASE_STOP - dist * 0.04, PATH_MIN_STOP, PATH_BASE_STOP)
if dist <= stopDist then if conn then conn:Disconnect() end hrp.AssemblyLinearVelocity = Vector3.zero reached = true return end
local moveDir = dir.Unit
if nextPoint then
local nextDir = (Vector3.new(nextPoint.X, pos.Y, nextPoint.Z) - pos).Unit
moveDir = (moveDir + nextDir * PATH_NEXT_POINT_BIAS).Unit
end
if lastFlatVel.Magnitude > 0.1 then
moveDir = (moveDir * (1 - PATH_SMOOTH_FACTOR) + lastFlatVel.Unit * PATH_SMOOTH_FACTOR).Unit
end
local vel = Vector3.new(moveDir.X * speed, hrp.AssemblyLinearVelocity.Y, moveDir.Z * speed)
hrp.AssemblyLinearVelocity = vel
lastFlatVel = Vector3.new(vel.X, 0, vel.Z)
end)
while pathActive and not reached and (Vector3.new(hrp.Position.X, 0, hrp.Position.Z) - Vector3.new(current.X, 0, current.Z)).Magnitude > PATH_BASE_STOP do
if isPlayerRagdolled() then pathPaused = true end
while pathActive and pathPaused do RunService.Heartbeat:Wait() end
if not pathActive then break end
RunService.Heartbeat:Wait()
end
if conn then conn:Disconnect() end
hrp.AssemblyLinearVelocity = Vector3.zero
return true
end

local function runStealPath(path)
local char = Player.Character or Player.CharacterAdded:Wait()
local hrp = char:WaitForChild("HumanoidRootPart")
local startIndex = currentPathIndex
if startIndex > #path then startIndex = 1 end
for i = startIndex, #path do
if not pathActive then return false end
while isPlayerRagdolled() and pathActive do pathPaused = true RunService.Heartbeat:Wait() end
if not pathActive then return false end
pathPaused = false
currentPathIndex = i
local speed = i > 2 and PATH_SECOND_SPEED or PATH_VELOCITY_SPEED
local nextP = path[i + 1] and path[i + 1].pos
local success = pathMoveToPoint(hrp, path[i].pos, nextP, speed)
if not success then return false end
if i == 2 then task.wait(AutoStealValues.PATH_TURN_WAIT) else task.wait(0.01) end
if not pathActive then return false end
end
return true
end

local function startStealPath(path, pathType)
if pathActive then return end
pathActive = true
currentPathIndex = 1
currentPathType = pathType

task.spawn(function()
while pathActive do
local completed = runStealPath(path)
if completed then
pathActive = false
currentPathIndex = 1

if currentPathType == "Right" then
Features.AutoRight = false
if _G["UpdateVisual_AutoRight"] then _G["UpdateVisual_AutoRight"](false) end
elseif currentPathType == "Left" then
Features.AutoLeft = false
if _G["UpdateVisual_AutoLeft"] then _G["UpdateVisual_AutoLeft"](false) end
end

local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
if hrp then hrp.AssemblyLinearVelocity = Vector3.zero end
break
else
while pathActive and isPlayerRagdolled() do pathPaused = true RunService.Heartbeat:Wait() end
if not pathActive then break end
pathPaused = false
end
end
end)
end

local function stopStealPath()
pathActive = false
pathPaused = false
currentPathIndex = 1
local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
if hrp then hrp.AssemblyLinearVelocity = Vector3.zero end
end

