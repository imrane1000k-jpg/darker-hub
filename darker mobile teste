mainFrame.BorderSizePixel = 0
mainFrame.Active = true
mainFrame.Draggable = true
Instance.new("UICorner", mainFrame).CornerRadius = UDim.new(0, 12 * guiScale)

local stroke = Instance.new("UIStroke", mainFrame)
stroke.Color = COLOR_ACCENT
stroke.Thickness = 2.5 * guiScale

-- Header
local header = Instance.new("Frame", mainFrame)
header.Size = UDim2.new(1, 0, 0, 45 * guiScale)
header.BackgroundColor3 = COLOR_BG_ROW
header.BorderSizePixel = 0
Instance.new("UICorner", header).CornerRadius = UDim.new(0, 12 * guiScale)

local title = Instance.new("TextLabel", header)
title.Size = UDim2.new(0.8, 0, 1, 0)
