-- ╚════════════════════════════════════════════════════════════════════╝
closeBtn.MouseButton1Click:Connect(function()
    scriptActive = false; infinityJumpEnabled = false; spaceHeld = false; mobileJumpHeld = false
    setInfinityJump(false)  -- Restore original jump button
    pcall(stopSpeedBoost); pcall(stopAntiRagdoll); pcall(stopFloat); pcall(stopHelicopter)
    pcall(stopSpeedWhileStealing); pcall(stopAutoSteal); pcall(stopSpamBat); pcall(stopGalaxy)
    pcall(stopUnwalk); pcall(disableOptimizer); pcall(stopStealPath); pcall(stopFrontLock)
    for _, conn in ipairs(AllRunConnections) do pcall(function() conn:Disconnect() end) end
    AllRunConnections = {}
    if rainbowTask then pcall(function() task.cancel(rainbowTask) end); rainbowTask = nil end
    for p, data in pairs(enemyTimers) do
        if data.Connection then pcall(function() data.Connection:Disconnect() end) end
        if data.Gui then pcall(function() data.Gui:Destroy() end) end
    end
    enemyTimers = {}
    if progressConn then pcall(function() progressConn:Disconnect() end) end
    if speedCounterGui then pcall(function() speedCounterGui:Destroy() end) end
    speedCounterGui = nil
    pcall(function() sg:Destroy() end)
end)

hideBtn.MouseButton1Click:Connect(function() TweenService:Create(main, TweenInfo.new(0.2), {Size = UDim2.new(0, W, 0, HeaderH)}):Play() end)
header.InputBegan:Connect(function(input)
