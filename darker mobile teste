local function createGalaxyBtn(text, color)
    local b = Instance.new("TextButton", cube)
    b.Text = text
    b.BackgroundColor3 = Color3.fromRGB(10, 10, 25)
    b.TextColor3 = color
    b.Font = Enum.Font.GothamMedium
    b.TextSize = 9
    
    local corner = Instance.new("UICorner", b)
    corner.CornerRadius = UDim.new(0, 10)
    
    local stroke = Instance.new("UIStroke", b)
    stroke.Thickness = 2
    stroke.Color = color
    
    task.spawn(function()
        while task.wait(0.1) do
            stroke.Transparency = 0.3 + (math.sin(tick() * 3) * 0.3)
        end
    end)
    return b
end

