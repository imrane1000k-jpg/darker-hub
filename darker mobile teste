title.Text = "MOBILE HUB"
title.Font = Enum.Font.GothamBold
title.TextSize = 14 * guiScale
title.TextColor3 = COLOR_TEXT
title.TextXAlignment = Enum.TextXAlignment.Left
title.Position = UDim2.new(0, 10 * guiScale, 0, 0)

local closeBtn = Instance.new("TextButton", header)
closeBtn.Size = UDim2.new(0, 30 * guiScale, 0, 30 * guiScale)
closeBtn.Position = UDim2.new(1, -35 * guiScale, 0.5, -15 * guiScale)
closeBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
closeBtn.Text = "✕"
closeBtn.TextColor3 = COLOR_TEXT
closeBtn.Font = Enum.Font.GothamBold
closeBtn.TextSize = 14 * guiScale
closeBtn.BorderSizePixel = 0
Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 6 * guiScale)

-- Content Area
local content = Instance.new("Frame", mainFrame)
content.Size = UDim2.new(1, 0, 1, -45 * guiScale)
content.Position = UDim2.new(0, 0, 0, 45 * guiScale)
content.BackgroundTransparency = 1

local listLayout = Instance.new("UIListLayout", content)
listLayout.Padding = UDim.new(0, 8 * guiScale)
listLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center

-- ─── TOUCH KEYBIND BUTTONS ────────────────────────
local buttons = {
    {name="LEFT STEAL", key="AutoLeft", color=GALAXY_LEFT},
    {name="RIGHT STEAL", key="AutoRight", color=GALAXY_RIGHT},
    {name="FRONT LOCK", key="FrontLock", color=GALAXY_LOCK},
    {name="DROP", key="performDrop", color=GALAXY_DROP}
}

for i, btnData in ipairs(buttons) do
    local btn = Instance.new("TextButton", content)
    btn.Size = UDim2.new(1, -20 * guiScale, 0, 50 * guiScale)
    btn.BackgroundColor3 = COLOR_BG_ROW
    btn.BackgroundTransparency = 0.3
    btn.Text = btnData.name
    btn.TextColor3 = btnData.color
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 11 * guiScale
    btn.BorderSizePixel = 0
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10 * guiScale)
    
    local btnStroke = Instance.new("UIStroke", btn)
    btnStroke.Color = btnData.color
    btnStroke.Thickness = 2 * guiScale
    btnStroke.Transparency = 0.3
    
    -- Button Logic (Syncs with your main script)
    btn.MouseButton1Click:Connect(function()
        -- Press effect
        TweenService:Create(btn, TweenInfo.new(0.1), {Size = UDim2.new(1, -25 * guiScale, 0, 45 * guiScale)}):Play()
        TweenService:Create(btnStroke, TweenInfo.new(0.1), {Transparency = 0}):Play()
        
        -- Execute
        if btnData.key == "performDrop" then
            if performDrop then performDrop() end
        else
            local toggleFunc = _G["Toggle" .. btnData.key]
            if toggleFunc then toggleFunc() end
        end
        
        task.wait(0.1)
        TweenService:Create(btn, TweenInfo.new(0.1), {Size = UDim2.new(1, -20 * guiScale, 0, 50 * guiScale)}):Play()
        TweenService:Create(btnStroke, TweenInfo.new(0.1), {Transparency = 0.3}):Play()
    end)
end

-- Close Button
closeBtn.MouseButton1Click:Connect(function()
    sg:Destroy()
end)

print("📱 Mobile GUI + Keybinds Loaded! (Right Middle)")
print("Drag to move • Touch buttons for controls")
