rainbowTask = task.spawn(function()
    local hue = 260
    while scriptActive and main and main.Parent do
        hue = (hue + 0.8) % 360
        local col = Color3.fromHSV(hue / 360, 0.8, 1)
        for _, elem in ipairs(rainbowElements) do pcall(function() elem.Color = col end) end
        task.wait(0.04)
    end
end)

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe or not scriptActive then return end
    if input.KeyCode == Keybinds.ToggleMenu then
        if main.Parent then if main.Size.Y.Offset <= HeaderH + 5 then main.Size = UDim2.new(0, W, 0, H) else main.Size = UDim2.new(0, W, 0, HeaderH) end end; return
    end
    if input.KeyCode == Keybinds.DropShot then performDrop(); return end
    local function syncToggle(featureName, newState, noSave)
        Features[featureName] = newState
        if featureName == "InfinityJump" then 
            infinityJumpEnabled = newState
            setInfinityJump(newState)
        end
        if _G["UpdateVisual_"..featureName] then _G["UpdateVisual_"..featureName](newState) end
        if not noSave then SaveConfig() end
    end
    if input.KeyCode == Keybinds.SpeedBoost then local s = not Features.SpeedBoost; syncToggle("SpeedBoost", s, false); if s then startSpeedBoost() else stopSpeedBoost() end; return end
    if input.KeyCode == Keybinds.AntiRagdoll then local s = not Features.AntiRagdoll; syncToggle("AntiRagdoll", s, false); if s then startAntiRagdoll() else stopAntiRagdoll() end; return end
    if input.KeyCode == Keybinds.InfinityJump then syncToggle("InfinityJump", not Features.InfinityJump, false); return end
    if input.KeyCode == Keybinds.Float then local s = not Features.Float; syncToggle("Float", s, false); if s then startFloat() else stopFloat() end; return end
    if input.KeyCode == Keybinds.Helicopter then local s = not Features.Helicopter; syncToggle("Helicopter", s, false); if s then startHelicopter() else stopHelicopter() end; return end
    if input.KeyCode == Keybinds.AutoRightSteal then
        local s = not Features.AutoRight
        if s then if Features.AutoLeft then Features.AutoLeft = false; if _G["UpdateVisual_AutoLeft"] then _G["UpdateVisual_AutoLeft"](false) end end end
        syncToggle("AutoRight", s, true); if s then stopStealPath(); startStealPath(stealPath1) else stopStealPath() end; return
    end
    if input.KeyCode == Keybinds.AutoLeftSteal then
        local s = not Features.AutoLeft
        if s then if Features.AutoRight then Features.AutoRight = false; if _G["UpdateVisual_AutoRight"] then _G["UpdateVisual_AutoRight"](false) end end end
        syncToggle("AutoLeft", s, true); if s then stopStealPath(); startStealPath(stealPath2) else stopStealPath() end; return
    end
    if input.KeyCode == Keybinds.FrontLock then local s = not Features.FrontLock; syncToggle("FrontLock", s, false); if s then startFrontLock() else stopFrontLock() end; return end
end)

