        if not pathActive or not scriptActive or isPlayerRagdolled() then if conn then conn:Disconnect() end; hrp.AssemblyLinearVelocity = Vector3.zero; reached = true; return end
        local pos = hrp.Position; local target = Vector3.new(current.X, pos.Y, current.Z); local dir = target - pos; local dist = dir.Magnitude
        local stopDist = math.clamp(PATH_BASE_STOP - dist * 0.04, PATH_MIN_STOP, PATH_BASE_STOP)
        if dist <= stopDist then if conn then conn:Disconnect() end; hrp.AssemblyLinearVelocity = Vector3.zero; reached = true; return end
        local moveDir = dir.Unit
        if nextPoint then local nextDir = (Vector3.new(nextPoint.X, pos.Y, nextPoint.Z) - pos).Unit; moveDir = (moveDir + nextDir * PATH_NEXT_POINT_BIAS).Unit end
        local lastFlat = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
        if lastFlat.Magnitude > 0.1 then moveDir = (moveDir * (1 - PATH_SMOOTH_FACTOR) + lastFlat.Unit * PATH_SMOOTH_FACTOR).Unit end
        hrp.AssemblyLinearVelocity = Vector3.new(moveDir.X * speed, 0, moveDir.Z * speed)
    end)
    while pathActive and scriptActive and not reached and not isPlayerRagdolled() and (Vector3.new(hrp.Position.X, 0, hrp.Position.Z) - Vector3.new(current.X, 0, current.Z)).Magnitude > PATH_BASE_STOP do RunService.Heartbeat:Wait() end
    if conn then conn:Disconnect() end
    hrp.AssemblyLinearVelocity = Vector3.zero
    return not isPlayerRagdolled() and scriptActive
end

local function runStealPath(path)
    local char = Player.Character or Player.CharacterAdded:Wait(); local hrp = char:WaitForChild("HumanoidRootPart")
    for i, p in ipairs(path) do
        if isPlayerRagdolled() or not pathActive or not scriptActive then return false end
        local speed = i > 2 and PATH_SECOND_SPEED or PATH_VELOCITY_SPEED
        local nextP = path[i + 1] and path[i + 1].pos
        local success = pathMoveToPoint(hrp, p.pos, nextP, speed)
        if not success then return false end
        if i == 2 then task.wait(AutoStealValues.PATH_TURN_WAIT) else RunService.Heartbeat:Wait() end
        if isPlayerRagdolled() or not pathActive or not scriptActive then return false end
    end
    return true
end

local function startStealPath(path)
    if pathActive then return end
    pathActive = true
    task.spawn(function()
        while pathActive and scriptActive do
            local completed = runStealPath(path)
            if not completed then
                while pathActive and scriptActive and isPlayerRagdolled() do RunService.Heartbeat:Wait() end
                if not pathActive or not scriptActive then break end
            else task.wait(0.05) end
        end
    end)
end
local function stopStealPath()
    pathActive = false
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.AssemblyLinearVelocity = Vector3.zero end
end

