local toggleSliderOrder = 0

local function makeToggleHeader(parent, labelText, featureName, hasKeybind, defaultKeycode, noSave)
    local frame = Instance.new("Frame", parent)
    frame.Size = UDim2.new(1, -8 * guiScale, 0, 36 * guiScale)
    frame.BackgroundColor3 = COLOR_BG_ROW
    frame.BackgroundTransparency = 0.4
    frame.BorderSizePixel = 0
    frame.LayoutOrder = toggleSliderOrder
    toggleSliderOrder = toggleSliderOrder + 1
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6 * guiScale)
    local fStroke = Instance.new("UIStroke", frame)
    fStroke.Thickness = 1.5 * guiScale
    fStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    fStroke.Color = COLOR_ACCENT
    table.insert(rainbowElements, fStroke)

    local lbl = Instance.new("TextLabel", frame)
    lbl.Size = UDim2.new(0.65, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = labelText
    lbl.TextColor3 = COLOR_DIM
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 11 * guiScale
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    local bg = Instance.new("Frame", frame)
    bg.Size = UDim2.new(0, 38 * guiScale, 0, 18 * guiScale)
    bg.Position = UDim2.new(1, -44 * guiScale, 0.5, -9 * guiScale)
    bg.BackgroundColor3 = COLOR_OFF
    bg.ZIndex = 4
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)

    local circle = Instance.new("Frame", bg)
    circle.Size = UDim2.new(0, 14 * guiScale, 0, 14 * guiScale)
    circle.Position = UDim2.new(0, 2 * guiScale, 0.5, -7 * guiScale)
    circle.BackgroundColor3 = Color3.new(0.8, 0.8, 0.9)
    circle.ZIndex = 5
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)

    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.ZIndex = 6

    local isOn = false
    local currentKeybind = defaultKeycode
    local listeningForKey = false

    local function updateVisual(state)
        if state ~= nil then isOn = state end
        if isOn then
            TweenService:Create(bg, TweenInfo.new(0.2), {BackgroundColor3 = COLOR_ACCENT}):Play()
            TweenService:Create(circle, TweenInfo.new(0.2), {Position = UDim2.new(1, -16 * guiScale, 0.5, -7 * guiScale)}):Play()
            lbl.TextColor3 = COLOR_GLOW
        else
            TweenService:Create(bg, TweenInfo.new(0.2), {BackgroundColor3 = COLOR_OFF}):Play()
            TweenService:Create(circle, TweenInfo.new(0.2), {Position = UDim2.new(0, 2 * guiScale, 0.5, -7 * guiScale)}):Play()
            lbl.TextColor3 = COLOR_DIM
        end
        if lbl and hasKeybind and currentKeybind then
            lbl.Text = string.gsub(labelText, "%[.*%]", "[" .. currentKeybind.Name .. "]")
        elseif lbl then lbl.Text = labelText end
    end

    if featureName then
        _G["UpdateVisual_"..featureName] = updateVisual
        if hasKeybind then
            _G["GetKeybind_"..featureName] = function() return currentKeybind end
            _G["SetKeybind_"..featureName] = function(k) currentKeybind = k; updateVisual(); if not noSave then SaveConfig() end end
        end
    end

    if hasKeybind then
        local kbBtn = Instance.new("TextButton", frame)
        kbBtn.Size = UDim2.new(0, 32 * guiScale, 0, 16 * guiScale)
        kbBtn.Position = UDim2.new(1, -82 * guiScale, 0.5, -8 * guiScale)
        kbBtn.BackgroundColor3 = COLOR_BG_MAIN
        kbBtn.TextColor3 = COLOR_GLOW
        kbBtn.Font = Enum.Font.GothamBold
        kbBtn.TextSize = 8 * guiScale
        kbBtn.Text = "BIND"
        kbBtn.BorderSizePixel = 0
        kbBtn.ZIndex = 8
        Instance.new("UICorner", kbBtn).CornerRadius = UDim.new(0, 4 * guiScale)
        local kbStroke = Instance.new("UIStroke", kbBtn)
        kbStroke.Thickness = 1 * guiScale
        kbStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        kbStroke.Color = COLOR_ACCENT
        table.insert(rainbowElements, kbStroke)
        kbBtn.MouseButton1Click:Connect(function()
            if listeningForKey then return end
            listeningForKey = true; kbBtn.Text = "..."; kbBtn.TextColor3 = COLOR_TEXT
            local conn
            conn = UserInputService.InputBegan:Connect(function(input)
                if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
                conn:Disconnect(); currentKeybind = input.KeyCode; listeningForKey = false; kbBtn.Text = "BIND"; kbBtn.TextColor3 = COLOR_GLOW
                updateVisual(); if not noSave then SaveConfig() end
            end)
        end)
    end
    return btn, updateVisual, function() return isOn end, function() return currentKeybind end
end

local function createSlider(parent, labelText, minVal, maxVal, valueKey, onChange)
    local container = Instance.new("Frame", parent)
    container.Size = UDim2.new(1, -8 * guiScale, 0, 40 * guiScale)
    container.BackgroundColor3 = COLOR_BG_ROW
    container.BackgroundTransparency = 0.4
    container.BorderSizePixel = 0
    container.LayoutOrder = toggleSliderOrder
    toggleSliderOrder = toggleSliderOrder + 1
    Instance.new("UICorner", container).CornerRadius = UDim.new(0, 6 * guiScale)
    local cStroke = Instance.new("UIStroke", container)
    cStroke.Thickness = 1.5 * guiScale
    cStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    cStroke.Color = COLOR_ACCENT
    table.insert(rainbowElements, cStroke)

    local label = Instance.new("TextLabel", container)
    label.Size = UDim2.new(1, 0, 0, 14 * guiScale)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextColor3 = COLOR_DIM
    label.Font = Enum.Font.GothamBold
    label.TextSize = 10 * guiScale
    label.TextXAlignment = Enum.TextXAlignment.Left

    local sliderBg = Instance.new("Frame", container)
    sliderBg.Size = UDim2.new(1, 0, 0, 5 * guiScale)
    sliderBg.Position = UDim2.new(0, 0, 0, 20 * guiScale)
    sliderBg.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    Instance.new("UICorner", sliderBg).CornerRadius = UDim.new(1, 0)

    local sliderFill = Instance.new("Frame", sliderBg)
    sliderFill.Size = UDim2.new(0.5, 0, 1, 0)
    sliderFill.BackgroundColor3 = COLOR_ACCENT
    Instance.new("UICorner", sliderFill).CornerRadius = UDim.new(1, 0)

    local thumb = Instance.new("Frame", sliderBg)
    thumb.Size = UDim2.new(0, 10 * guiScale, 0, 10 * guiScale)
    thumb.Position = UDim2.new(0.5, -5 * guiScale, 0.5, -5 * guiScale)
    thumb.BackgroundColor3 = COLOR_GLOW
    Instance.new("UICorner", thumb).CornerRadius = UDim.new(1, 0)

    local valueLabel = Instance.new("TextLabel", container)
    valueLabel.Size = UDim2.new(0, 35 * guiScale, 0, 14 * guiScale)
    valueLabel.Position = UDim2.new(1, -38 * guiScale, 0, 0)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Text = tostring(Values[valueKey] or AutoStealValues[valueKey])
    valueLabel.TextColor3 = COLOR_GLOW
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.TextSize = 10 * guiScale

    local dragging = false
    local function updateSliderVisual(value)
        local relative = (value - minVal) / (maxVal - minVal)
        relative = math.clamp(relative, 0, 1)
        if valueKey == "STEAL_DURATION" or valueKey == "PATH_TURN_WAIT" then
            valueLabel.Text = string.format("%.2f", value) .. "s"
        else
            valueLabel.Text = tostring(value)
        end
        sliderFill.Size = UDim2.new(relative, 0, 1, 0)
        thumb.Position = UDim2.new(relative, -5 * guiScale, 0.5, -5 * guiScale)
        if onChange then onChange(value) end
    end

    SliderReferences[valueKey] = { func = updateSliderVisual }
    local function updateSlider(inputRelative)
        inputRelative = math.clamp(inputRelative, 0, 1)
        if valueKey == "STEAL_DURATION" or valueKey == "PATH_TURN_WAIT" then
            local decimalVal = minVal + (maxVal - minVal) * inputRelative
            decimalVal = tonumber(string.format("%.2f", decimalVal))
            if AutoStealValues[valueKey] then AutoStealValues[valueKey] = decimalVal end
            updateSliderVisual(decimalVal); SaveConfig(); return
        end
        local value = math.floor(minVal + (maxVal - minVal) * inputRelative)
        if Values[valueKey] then Values[valueKey] = value elseif AutoStealValues[valueKey] then AutoStealValues[valueKey] = value end
        updateSliderVisual(value); SaveConfig()
    end

    sliderBg.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true end end)
    UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end end)
    UserInputService.InputChanged:Connect(function(input) if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then local relative = (input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X; updateSlider(relative) end end)
    local currentVal = Values[valueKey] or AutoStealValues[valueKey]
    if currentVal then updateSliderVisual(currentVal) end
    return container
end

