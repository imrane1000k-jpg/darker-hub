local function createGalaxyBtn(text, colorOff, featureKey)
    local b = Instance.new("TextButton", cubeContainer)
    b.Text = text
    b.BackgroundColor3 = COLOR_BG_MAIN
    b.TextColor3 = colorOff
    b.Font = Enum.Font.GothamBlack
    b.TextSize = 11 * guiScale
    b.AutoButtonColor = false
    
    local btnCorner = Instance.new("UICorner", b)
    btnCorner.CornerRadius = UDim.new(0, 12 * guiScale)
    
    local btnStroke = Instance.new("UIStroke", b)
    btnStroke.Thickness = 2.5 * guiScale
    btnStroke.Color = colorOff
    
    task.spawn(function()
        while b.Parent do
            local isActive = Features[featureKey]
            local targetTrans = isActive and 0 or 0.3
            local pulse = math.sin(tick() * 5) * 0.1
            btnStroke.Transparency = targetTrans + pulse
            task.wait(0.03)
        end
    end)
    
    return b, btnStroke
end

