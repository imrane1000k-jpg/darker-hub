-- ╔══════════════════════════════════════════════════════════════════════════════╗
-- ║  📱 MOBILE ONLY: Keybind Grid (Renamed Features)                               ║
-- ╚══════════════════════════════════════════════════════════════════════════════╝

if isMobile then
    local CELL_W = 62; local CELL_H = 44; local GAP = 5; local PAD = 8
    local gridInnerW = (CELL_W * 3) + (GAP * 2)
    local gridInnerH = (CELL_H * 2) + (GAP * 1)
    local boxW = gridInnerW + (PAD * 2); local boxH = gridInnerH + (PAD * 2)

    local mobileFrame = Instance.new("Frame")
    mobileFrame.Name = "MobileGrid"
    mobileFrame.Size = UDim2.new(0, boxW, 0, boxH)
    mobileFrame.Position = UDim2.new(1, -boxW - 8, 0.5, -boxH / 2)
    mobileFrame.BackgroundColor3 = Color3.fromRGB(8, 8, 25)
    mobileFrame.BackgroundTransparency = 0.12; mobileFrame.Visible = true; mobileFrame.ZIndex = 50
    Instance.new("UICorner", mobileFrame).CornerRadius = UDim.new(0, 14)
    local boxStroke = Instance.new("UIStroke", mobileFrame)
    boxStroke.Color = COLOR_ACCENT; boxStroke.Thickness = 2; boxStroke.Transparency = 0.25

    local innerPad = Instance.new("Frame", mobileFrame)
    innerPad.Name = "Inner"; innerPad.Size = UDim2.new(1, -PAD * 2, 1, -PAD * 2)
    innerPad.Position = UDim2.new(0, PAD, 0, PAD); innerPad.BackgroundTransparency = 1

    local gridLayout = Instance.new("UIGridLayout", innerPad)
    gridLayout.CellSize = UDim2.new(0, CELL_W, 0, CELL_H)
    gridLayout.CellPadding = UDim2.new(0, GAP, 0, GAP)
    gridLayout.SortOrder = Enum.SortOrder.LayoutOrder

    mobileFrame.Parent = sg
    table.insert(rainbowElements, boxStroke)

    local function createGridButton(text, featureKey, buttonType, order)
        -- buttonType: "toggle", "hold" (InfJump), "instant" (Drop)
        
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, CELL_W, 0, CELL_H)
        btn.BackgroundColor3 = Color3.fromRGB(12, 12, 35)
        btn.TextColor3 = COLOR_GLOW; btn.Font = Enum.Font.GothamBlack; btn.TextSize = 11
        btn.Text = text; btn.BorderSizePixel = 0; btn.ZIndex = 55; btn.AutoButtonColor = false
        btn.LayoutOrder = order
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)
        local stroke = Instance.new("UIStroke", btn)
        stroke.Color = COLOR_ACCENT; stroke.Thickness = 1.5; stroke.Transparency = 0.4
        table.insert(rainbowElements, stroke)
        
        local dot = Instance.new("Frame", btn)
        dot.Size = UDim2.new(0, 8, 0, 8); dot.Position = UDim2.new(1, -12, 0, 4)
        dot.BackgroundColor3 = Color3.fromRGB(60, 60, 60); dot.BorderSizePixel = 0; dot.ZIndex = 56
        Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
        
        local function updateGridVisual(state)
            if state then
                TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(80, 30, 140)}):Play()
                TweenService:Create(dot, TweenInfo.new(0.15), {BackgroundColor3 = COLOR_GLOW}):Play()
                btn.TextColor3 = COLOR_TEXT
            else
                TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(12, 12, 35)}):Play()
                TweenService:Create(dot, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(60, 60, 60)}):Play()
                btn.TextColor3 = COLOR_GLOW
            end
        end
        
        if buttonType == "toggle" and featureKey then
            MobileGridButtons[featureKey] = { Button = btn, Update = updateGridVisual }
            if Features[featureKey] then task.spawn(function() updateGridVisual(true) end) end
            
            btn.MouseButton1Click:Connect(function()
                if not scriptActive then return end
                
                local newState = not Features[featureKey]
                
                if featureKey == "AutoRight" and newState then 
                    Features.AutoLeft = false; stopStealPath() 
                    if _G["UpdateVisual_AutoLeft"] then _G["UpdateVisual_AutoLeft"](false) end 
                elseif featureKey == "AutoLeft" and newState then 
                    Features.AutoRight = false; stopStealPath() 
                    if _G["UpdateVisual_AutoRight"] then _G["UpdateVisual_AutoRight"](false) end 
                end
                
                Features[featureKey] = newState
                
                if featureKey == "Float" then 
                    if newState then startFloat() else stopFloat() end
                elseif featureKey == "Helicopter" then 
                    if newState then startHelicopter() else stopHelicopter() end
                elseif featureKey == "FrontLock" then 
                    if newState then startFrontLock() else stopFrontLock() end
                elseif featureKey == "SpeedBoost" then 
                    if newState then startSpeedBoost() else stopSpeedBoost() end
                elseif featureKey == "AntiRagdoll" then 
                    if newState then startAntiRagdoll() else stopAntiRagdoll() end
                elseif featureKey == "AutoRight" then 
                    if newState then startStealPath(stealPath1) else stopStealPath() end
                elseif featureKey == "AutoLeft" then 
                    if newState then startStealPath(stealPath2) else stopStealPath() end 
                end
                
                if _G["UpdateVisual_"..featureKey] then 
                    _G["UpdateVisual_"..featureKey](newState) 
                end
                
                if featureKey ~= "AutoRight" and featureKey ~= "AutoLeft" then
                    SaveConfig()
                end
            end)
            
        elseif buttonType == "hold" then
            -- HOLD BUTTON (InfJump)
            
            if not Features.InfinityJump then
                Features.InfinityJump = true
                infinityJumpEnabled = true
            end
            
            btn.MouseButton1Down:Connect(function()
                if not scriptActive then return end
                mobileInfJumpHeld = true
                TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(0, 180, 255)}):Play()
                btn.TextColor3 = COLOR_TEXT
                dot.BackgroundColor3 = COLOR_GLOW
            end)
            
            btn.MouseButton1Up:Connect(function()
                mobileInfJumpHeld = false
                TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(12, 12, 35)}):Play()
                btn.TextColor3 = COLOR_GLOW
                dot.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
            end)
            
            btn.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.Touch then
                    mobileInfJumpHeld = false
                    TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(12, 12, 35)}):Play()
                    btn.TextColor3 = COLOR_GLOW
                    dot.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
                end
            end)
            
        elseif buttonType == "instant" then
            btn.MouseButton1Click:Connect(function()
                if not scriptActive then return end
                performDrop()
                TweenService:Create(btn, TweenInfo.new(0.08), {BackgroundColor3 = COLOR_GLOW}):Play()
                task.wait(0.12)
                TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = Color3.fromRGB(12, 12, 35)}):Play()
            end)
        end
        
        btn.Parent = innerPad
        return btn
    end

    -- ══════════════════════════════════════════════════════════════
    -- 📱 MOBILE GRID WITH RENAMED FEATURES!
    -- ══════════════════════════════════════════════════════════════
    
    -- Row 1: Auto Right, Auto Left, InfJump (Hold)
    createGridButton("Auto R\n[V]", "AutoRight", "toggle", 1)
    createGridButton("Auto L\n[C]", "AutoLeft", "toggle", 2)
    createGridButton("InfJump\n[Z] ✋", "InfinityJump", "hold", 3)
    
    -- Row 2: Spin Bot, Bat Lock, Drop
    createGridButton("SpinBot\n[G]", "Helicopter", "toggle", 4)     -- ← Renamed!
    createGridButton("BatLock\n[F]", "FrontLock", "toggle", 5)       -- ← Renamed!
    createGridButton("Drop\n[X]", nil, "instant", 6)

    print([[
╔═══════════════════════════════════════════════════════════════╗
║  📱 Mobile Grid Loaded!                                        ║
║  ✋ HOLD InfJump to FLOAT UP                                   ║
║  🔄 Auto R/L for stealing                                      ║
║  🔄 SpinBot, BatLock added!                                   ║
╚═══════════════════════════════════════════════════════════════╝
]])
end
