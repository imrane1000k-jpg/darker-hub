    l.Text = labelText; l.TextColor3 = COLOR_DIM; l.Font = Enum.Font.GothamBold; l.TextSize = 9 * guiScale; l.TextXAlignment = Enum.TextXAlignment.Left
    local sb = Instance.new("Frame", c); sb.Size = UDim2.new(1, 0, 0, 4 * guiScale); sb.Position = UDim2.new(0, 0, 0, 17 * guiScale); sb.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
