-- 📱 MOBILE GUI + KEYBINDS (Right Middle Position)
-- Complete standalone script for phone players only

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local Player = Players.LocalPlayer

local isMobile = UserInputService.TouchEnabled
if not isMobile then return end -- Phone only

local guiScale = math.clamp(workspace.CurrentCamera.ViewportSize.Y / 1000, 0.8, 1.2)
local sg = Instance.new("ScreenGui")
sg.Name = "MobileKeybindsGUI"
sg.ResetOnSpawn = false
sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
sg.Parent = Player.PlayerGui

-- Colors
local GALAXY_LEFT = Color3.fromRGB(0, 100, 255)
local GALAXY_RIGHT = Color3.fromRGB(0, 255, 200)
local GALAXY_LOCK = Color3.fromRGB(200, 0, 255)
local GALAXY_DROP = Color3.fromRGB(255, 50, 100)
local COLOR_TEXT = Color3.fromRGB(255, 255, 255)
local COLOR_BG_MAIN = Color3.fromRGB(5, 5, 20)
local COLOR_BG_ROW = Color3.fromRGB(20, 10, 40)
local COLOR_ACCENT = Color3.fromRGB(138, 43, 226)

-- ─── MAIN MOBILE GUI (Right Middle) ────────────────────────
local mainFrame = Instance.new("Frame", sg)
mainFrame.Size = UDim2.new(0, 220 * guiScale, 0, 320 * guiScale)
