-- ─── ANTI-DETECTION UTILS ───────────────────────
local function applyJitteredVelocity(baseVel, jitterAmount)
    local jitter = Vector3.new(
        math.random(-jitterAmount*10, jitterAmount*10)/10,
        math.random(-jitterAmount*10, jitterAmount*10)/10,
        math.random(-jitterAmount*10, jitterAmount*10)/10
    )
    return baseVel + jitter
end

local function safeVelocitySet(hrp, targetVel)
    local currentVel = hrp.AssemblyLinearVelocity
    local blendedVel = currentVel:lerp(targetVel, 0.85)
    hrp.AssemblyLinearVelocity = applyJitteredVelocity(blendedVel, Values.JITTER_AMOUNT)
end

