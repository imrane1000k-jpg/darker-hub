local function LoadConfig()
    if not readfile then return end
    pcall(function()
        if isfile(ConfigFileName) then
            local data = HttpService:JSONDecode(readfile(ConfigFileName))
            for k, v in pairs(Features) do
                if k ~= "AutoRight" and k ~= "AutoLeft" and data[k] ~= nil then Features[k] = data[k] end
            end
            if data.BoostSpeed then Values.BoostSpeed = data.BoostSpeed end
            if data.SpinSpeed then Values.SpinSpeed = data.SpinSpeed end
            if data.GalaxyGravityPercent then Values.GalaxyGravityPercent = data.GalaxyGravityPercent end
            if data.StealingSpeedValue then Values.StealingSpeedValue = data.StealingSpeedValue end
            if data.HOP_POWER then Values.HOP_POWER = data.HOP_POWER end
            if data.HOP_COOLDOWN then Values.HOP_COOLDOWN = data.HOP_COOLDOWN end
            if data.STEAL_RADIUS then AutoStealValues.STEAL_RADIUS = data.STEAL_RADIUS end
            if data.STEAL_DURATION then AutoStealValues.STEAL_DURATION = data.STEAL_DURATION end
            if data.PATH_TURN_WAIT then AutoStealValues.PATH_TURN_WAIT = data.PATH_TURN_WAIT end
            if data.KEY_SPEED then Keybinds.SpeedBoost = Enum.KeyCode[data.KEY_SPEED] or Keybinds.SpeedBoost end
            if data.KEY_ANTIRAG then Keybinds.AntiRagdoll = Enum.KeyCode[data.KEY_ANTIRAG] or Keybinds.AntiRagdoll end
            if data.KEY_INFJUMP then Keybinds.InfinityJump = Enum.KeyCode[data.KEY_INFJUMP] or Keybinds.InfinityJump end
            if data.KEY_HELI then Keybinds.Helicopter = Enum.KeyCode[data.KEY_HELI] or Keybinds.Helicopter end
            if data.KEY_MENU then Keybinds.ToggleMenu = Enum.KeyCode[data.KEY_MENU] or Keybinds.ToggleMenu end
            if data.KEY_FRONTLOCK then Keybinds.FrontLock = Enum.KeyCode[data.KEY_FRONTLOCK] or Keybinds.FrontLock end
            if data.KEY_DROP then Keybinds.DropShot = Enum.KeyCode[data.KEY_DROP] or Keybinds.DropShot end
            if data.KEY_FLOAT then Keybinds.Float = Enum.KeyCode[data.KEY_FLOAT] or Keybinds.Float end
