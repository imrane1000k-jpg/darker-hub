pathActive = true
task.spawn(function()
while pathActive do
local completed = runStealPath(path)
if not completed then
while pathActive and isPlayerRagdolled() do RunService.Heartbeat:Wait() end
if not pathActive then break end
else task.wait(0.1) end
end
end)
end
