-- ║  📱 MOBILE CUSTOM JUMP BUTTON SYSTEM                          ║
-- ║  - Replaces jump button when InfJump enabled                 ║
-- ║  - HOLD to fly up, RELEASE to fall                          ║
-- ║  - Toggle off = Original jump returns                       ║
-- ╚═══════════════════════════════════════════════════════════════╝
local infinityJumpEnabled = false
local JUMP_BOOST_FORCE = 65
local customJumpButton = nil
local originalJumpButton = nil
local mobileJumpHeld = false

-- Find the default jump button
local function findJumpButton()
    -- Try to find the mobile jump button
    local playerGui = Player:FindFirstChild("PlayerGui")
    if not playerGui then return nil end
    
    -- Search for jump button in common locations
    for _, screenGui in ipairs(playerGui:GetChildren()) do
        if screenGui:IsA("ScreenGui") then
            -- Look for button with "Jump" in name or check TouchGui
            for _, desc in ipairs(screenGui:GetDescendants()) do
                if desc:IsA("GuiButton") then
                    local name = desc.Name:lower()
                    if name:find("jump") or name:find("mobilejumpbutton") then
                        return desc
                    end
                end
            end
        end
    end
    
    -- Fallback: Check TouchGui
    local touchGui = playerGui:FindFirstChild("TouchGui")
    if touchGui then
        local touchFrame = touchGui:FindFirstChild("TouchControlFrame")
        if touchFrame then
            local jumpButton = touchFrame:FindFirstChild("JumpButton")
            if jumpButton then return jumpButton end
        end
    end
    
    return nil
end

-- Create custom jump button that looks like original
local function createCustomJumpButton(originalButton)
    if not originalButton then return nil end
    
    -- Hide original
    originalButton.Visible = false
    
    -- Create clone
    local customBtn = Instance.new("TextButton")
    customBtn.Name = "DarkerHub_CustomJump"
    customBtn.Size = originalButton.Size
    customBtn.Position = originalButton.Position
    customBtn.AnchorPoint = originalButton.AnchorPoint
    customBtn.BackgroundColor3 = originalButton.BackgroundColor3
    customBtn.BackgroundTransparency = originalButton.BackgroundTransparency
    customBtn.BorderSizePixel = originalButton.BorderSizePixel
    customBtn.Text = originalButton.Text
    customBtn.TextColor3 = originalButton.TextColor3
    customBtn.Font = originalButton.Font
    customBtn.TextSize = originalButton.TextSize
    customBtn.AutoButtonColor = originalButton.AutoButtonColor
    customBtn Modal = false
    customBtn.ZIndex = originalButton.ZIndex + 100
    customBtn.Parent = originalButton.Parent
    
    -- Copy UI Stroke if exists
    if originalButton:FindFirstChildWhichIsA("UIStroke") then
        local stroke = Instance.new("UIStroke", customBtn)
        stroke.Color = COLOR_GLOW
        stroke.Thickness = 2
        stroke.Transparency = 0.3
    end
    
    -- Copy UICorner if exists
    if originalButton:FindFirstChildWhichIsA("UICorner") then
        local corner = Instance.new("UICorner", customBtn)
        corner.CornerRadius = UDim.new(0, 8)
    end
    
    -- Input handling for HOLD to fly
    customBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            mobileJumpHeld = true
            -- Visual feedback
            TweenService:Create(customBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(100, 100, 255)}):Play()
        end
    end)
    
    customBtn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            mobileJumpHeld = false
            -- Visual feedback
            TweenService:Create(customBtn, TweenInfo.new(0.1), {BackgroundColor3 = originalButton.BackgroundColor3}):Play()
        end
    end)
    
    return customBtn
end

-- Show/hide custom jump button
local function showCustomJumpButton()
    if not isMobile then return end
    
    originalJumpButton = findJumpButton()
    if originalJumpButton then
        customJumpButton = createCustomJumpButton(originalJumpButton)
    else
        -- If we can't find it, create our own floating button
        warn("[DarkerHub] Could not find original jump button, creating fallback")
        
