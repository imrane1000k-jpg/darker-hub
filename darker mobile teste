        if newState then 
            stopStealPath()
            startStealPath(stealPath2, "Left") 
        else 
            stopStealPath() 
        end
        
        -- Visual feedback
        if newState then
            leftFrame.BackgroundColor3 = Color3.fromRGB(100, 200, 255)
            leftIcon.Text = "◀✓"
        else
            leftFrame.BackgroundColor3 = Color3.fromRGB(50, 150, 255)
            leftIcon.Text = "◀"
        end
    end)
    
    -- Front Lock Button - Bottom Left Behind
    local lockFrame, lockBtn, lockIcon, lockText = createCornerButton(sg, UDim2.new(0, 20, 1, -85), Color3.fromRGB(200, 50, 255), "🎯", "LOCK", "FrontLock")
    lockBtn.MouseButton1Click:Connect(function()
        local newState = not Features.FrontLock
        Features.FrontLock = newState
        if _G["UpdateVisual_FrontLock"] then _G["UpdateVisual_FrontLock"](newState) end
        if newState then 
            startFrontLock() 
        else 
            stopFrontLock() 
        end
        
        -- Visual feedback
        if newState then
            lockFrame.BackgroundColor3 = Color3.fromRGB(230, 100, 255)
            lockIcon.Text = "🎯✓"
        else
            lockFrame.BackgroundColor3 = Color3.fromRGB(200, 50, 255)
            lockIcon.Text = "🎯"
        end
    end)

    -- *** ADDED: MOBILE INFINITY JUMP (HOLD) BUTTON ***
    local mobileInfJumpActive = false
    local mobileInfJumpConnection = nil

    local flyFrame, flyBtn, flyIcon, flyText = createCornerButton(sg, UDim2.new(1, -85, 0, 200), Color3.fromRGB(255, 120, 0), "🚀", "FLY", "Fly")
    
    flyBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            mobileInfJumpActive = true
            flyFrame.BackgroundColor3 = Color3.fromRGB(255, 180, 0)
            flyIcon.Text = "🚀✓"

            if mobileInfJumpConnection then mobileInfJumpConnection:Disconnect() end
            mobileInfJumpConnection = RunService.Heartbeat:Connect(function()
                if not mobileInfJumpActive then return end
                local char = Player.Character
                if not char then return end
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local currentVel = hrp.AssemblyLinearVelocity
                    hrp.AssemblyLinearVelocity = Vector3.new(currentVel.X, Values.UP_SPEED, currentVel.Z)
                end
            end)
        end
    end)

    flyBtn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            mobileInfJumpActive = false
            flyFrame.BackgroundColor3 = Color3.fromRGB(255, 120, 0)
            flyIcon.Text = "🚀"
            
            if mobileInfJumpConnection then
                mobileInfJumpConnection:Disconnect()
                mobileInfJumpConnection = nil
            end
        end
    end)
    
    -- Floating animation
    local function floatCornerButton(button)
        local floatUp = TweenService:Create(button, TweenInfo.new(2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1), {Position = button.Position + UDim2.new(0, 0, 0, -5)})
        floatUp:Play()
    end
    
    -- Apply floating animation to all buttons
    floatCornerButton(dropFrame)
    floatCornerButton(rightFrame)
    floatCornerButton(leftFrame)
    floatCornerButton(lockFrame)
    floatCornerButton(flyFrame)
    
    -- Update button states when features change
    local function updateMobileVisuals()
        -- Update Auto Right
        if Features.AutoRight then
            rightFrame.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
            rightIcon.Text = "▶✓"
        else
            rightFrame.BackgroundColor3 = Color3.fromRGB(50, 255, 50)
            rightIcon.Text = "▶"
        end
        
        -- Update Auto Left
        if Features.AutoLeft then
            leftFrame.BackgroundColor3 = Color3.fromRGB(100, 200, 255)
            leftIcon.Text = "◀✓"
        else
            leftFrame.BackgroundColor3 = Color3.fromRGB(50, 150, 255)
            leftIcon.Text = "◀"
        end
        
        -- Update Front Lock
        if Features.FrontLock then
            lockFrame.BackgroundColor3 = Color3.fromRGB(230, 100, 255)
            lockIcon.Text = "🎯✓"
        else
            lockFrame.BackgroundColor3 = Color3.fromRGB(200, 50, 255)
            lockIcon.Text = "🎯"
        end
    end
    
    -- Hook into visual updates
    if _G["UpdateVisual_AutoRight"] then
        local original = _G["UpdateVisual_AutoRight"]
        _G["UpdateVisual_AutoRight"] = function(state)
            original(state)
            updateMobileVisuals()
        end
    end
    
    if _G["UpdateVisual_AutoLeft"] then
        local original = _G["UpdateVisual_AutoLeft"]
        _G["UpdateVisual_AutoLeft"] = function(state)
            original(state)
            updateMobileVisuals()
        end
    end
    
    if _G["UpdateVisual_FrontLock"] then
        local original = _G["UpdateVisual_FrontLock"]
        _G["UpdateVisual_FrontLock"] = function(state)
            original(state)
            updateMobileVisuals()
        end
    end
    
    -- Initial state update
    updateMobileVisuals()
end

print("[Darker Hub] Loaded! Optimized & Mobile Fly Fix Applied.")
