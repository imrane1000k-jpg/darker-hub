local dragging = false
local function updateSliderVisual(value)
local relative = (value - minVal) / (maxVal - minVal)
relative = math.clamp(relative, 0, 1)
if valueKey == "STEAL_DURATION" or valueKey == "PATH_TURN_WAIT" then
valueLabel.Text = string.format("%.2f", value) .. "s"
else
valueLabel.Text = tostring(value)
end
sliderFill.Size = UDim2.new(relative, 0, 1, 0)
thumb.Position = UDim2.new(relative, -5 * guiScale, 0.5, -5 * guiScale)
if onChange then onChange(value) end
end
SliderReferences[valueKey] = { func = updateSliderVisual }
local function updateSlider(inputRelative)
inputRelative = math.clamp(inputRelative, 0, 1)
if valueKey == "STEAL_DURATION" or valueKey == "PATH_TURN_WAIT" then
local decimalVal = minVal + (maxVal - minVal) * inputRelative
decimalVal = tonumber(string.format("%.2f", decimalVal))
if AutoStealValues[valueKey] then AutoStealValues[valueKey] = decimalVal end
updateSliderVisual(decimalVal)
SaveConfig()
return
end
local value = math.floor(minVal + (maxVal - minVal) * inputRelative)
if Values[valueKey] then Values[valueKey] = value
elseif AutoStealValues[valueKey] then AutoStealValues[valueKey] = value end
updateSliderVisual(value)
SaveConfig()
end
sliderBg.InputBegan:Connect(function(input)
if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true end
end)
UserInputService.InputEnded:Connect(function(input)
if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
end)
UserInputService.InputChanged:Connect(function(input)
if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
local relative = (input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X
updateSlider(relative)
end
end)
local currentVal = Values[valueKey] or AutoStealValues[valueKey]
if currentVal then updateSliderVisual(currentVal) end
return container
end
