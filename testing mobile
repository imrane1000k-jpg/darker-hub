-- ✅ TOGGLE THE MAIN GUI AUTO LEFT/RIGHT BUTTONS (WITH VISUAL FEEDBACK)
local function toggleMainGUIAutoLeft(state)
    -- Update the global variable
    autoLOn = state
    
    if state then 
        startAutoL()
    else 
        stopAutoL()
    end
    
    -- Update the mobile button if exists (make it WHITE when ON)
    if mobBtnRefs and mobBtnRefs["AUTO L"] then
        mobBtnRefs["AUTO L"].state = state
        if mobBtnRefs["AUTO L"].btn then
            local btn = mobBtnRefs["AUTO L"].btn
            local bs = mobBtnRefs["AUTO L"].bs
            -- ✅ WHITE BACKGROUND WHEN ON!
            btn.BackgroundColor3 = state and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(25, 25, 30)
            if bs then 
                bs.Color = state and Color3.fromRGB(100, 200, 130) or Color3.fromRGB(60, 60, 70)
                bs.Thickness = state and 2.5 or 1.2
            end
            -- Update text color
            for _, child in ipairs(btn:GetDescendants()) do
                if child:IsA("TextLabel") then
                    child.TextColor3 = state and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(255, 255, 255)
                    child.TextStrokeTransparency = state and 1 or 0.35
                end
            end
        end
    end
    
    -- Also find and click the main GUI button to keep it synced
    local mainGui = player.PlayerGui:FindFirstChild("SomHub_V1_EnvyStyle")
    if mainGui then
        for _, btn in ipairs(mainGui:GetDescendants()) do
            if btn:IsA("TextButton") then
                local btnText = btn.Text or ""
                if btnText:upper() == "AUTO L" or btnText:upper() == "AUTO LEFT" then
                    -- Update its visual too
                    btn.BackgroundColor3 = state and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(25, 25, 30)
                    -- Update any stroke
                    for _, stroke in ipairs(btn:GetDescendants()) do
                        if stroke:IsA("UIStroke") then
                            stroke.Color = state and Color3.fromRGB(100, 200, 130) or Color3.fromRGB(60, 60, 70)
                        end
                    end
                end
            end
        end
    end
end

