    -- Speed Boost
    function Hub.startSpeedBoost()
        if Hub.Connections.speed then return end
        Hub.Connections.speed = RunService.Heartbeat:Connect(function()
            if not Hub.Enabled.SpeedBoost then return end
            pcall(function()
                local h = Hub.getHRP()
                if not h then return end
                local md = Hub.getMovementDirection()
                if md.Magnitude > 0.1 then
                    h.AssemblyLinearVelocity = Vector3.new(
                        md.X * Hub.Values.BoostSpeed, 
                        h.AssemblyLinearVelocity.Y, 
