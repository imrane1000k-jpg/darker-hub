                    gHrp.AssemblyLinearVelocity.Y, 
                    md.Z * spd
                )
            end
        end)
    end
    
    function Hub.startAutoPlayRightEx()
        if Hub.aprConn then Hub.aprConn:Disconnect() end
        Hub.aprPhase = 1
        local targets = {Hub.Pos.R1, Hub.Pos.R2, Vector3.new(-476.17, -7.91, 97.91)}
        
        Hub.aprConn = RunService.Heartbeat:Connect(function()
            if not Hub.aprOn then return end
            local gHrp = Hub.getHRP()
            local gHum = Hub.getHum()
            if not gHrp or not gHum then return end
            
            local tp = targets[Hub.aprPhase]
            local d = Vector3.new(tp.X - gHrp.Position.X, 0, tp.Z - gHrp.Position.Z)
            
            if d.Magnitude < 2 then
                if Hub.aprPhase == #targets then
                    gHum:Move(Vector3.zero, false)
                    gHrp.AssemblyLinearVelocity = Vector3.zero
                    Hub.aprOn = false
                    Hub.stopAutoPlayRightEx()
                    local info = Hub.mobBtnRefs["PLAY R"]
                    if info then 
                        info.btn.BackgroundColor3 = Color3.fromRGB(8, 8, 8)
                        info.bs.Color = Color3.fromRGB(40, 40, 50)
                        info.bs.Transparency = 0.2
                        info.state = false 
                    end
                    if Hub.toggleSetters["Play Right"] then 
                        Hub.toggleSetters["Play Right"](false) 
                    end
                    return
                end
                Hub.aprPhase = Hub.aprPhase + 1
            else
                local md = d.Unit
                gHum:Move(md, false)
                local spd = Hub.getAutoSpeed()
                gHrp.AssemblyLinearVelocity = Vector3.new(
                    md.X * spd, 
                    gHrp.AssemblyLinearVelocity.Y, 
                    md.Z * spd
                )
            end
        end)
    end
    
