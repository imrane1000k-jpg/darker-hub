-- Input Handling
C.UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	local kc = input.KeyCode
	if kc == Enum.KeyCode.Unknown then return end
	
	if kc == C.KEYBINDS.AUTOLEFT then
		C.Enabled.AutoWalkEnabled = not C.Enabled.AutoWalkEnabled
		if C.Enabled.AutoWalkEnabled then C.startAutoWalk() else C.stopAutoWalk() end
		if C.VisualSetters["Auto Left"] then C.VisualSetters["Auto Left"](C.Enabled.AutoWalkEnabled) end
		C.SaveConfig()
		
	elseif kc == C.KEYBINDS.AUTORIGHT then
		C.Enabled.AutoRightEnabled = not C.Enabled.AutoRightEnabled
		if C.Enabled.AutoRightEnabled then C.startAutoRight() else C.stopAutoRight() end
		if C.VisualSetters["Auto Right"] then C.VisualSetters["Auto Right"](C.Enabled.AutoRightEnabled) end
		C.SaveConfig()
		
	elseif kc == C.KEYBINDS.BATAIMBOT then
		C.Enabled.BatAimbot = not C.Enabled.BatAimbot
		if C.Enabled.BatAimbot then C.startBatAimbot() else C.stopBatAimbot() end
		if C.VisualSetters["Lock (Bat Aimbot)"] then C.VisualSetters["Lock (Bat Aimbot)"](C.Enabled.BatAimbot) end
		C.SaveConfig()
		
	elseif kc == C.KEYBINDS.DROP then
		task.spawn(function() C.startWalkFling(); task.delay(0.4, C.stopWalkFling) end)
		
	elseif kc == C.KEYBINDS.TPDOWN then
		task.spawn(C.doTPDown)
		
	elseif kc == C.KEYBINDS.AUTOSTEAL then
		C.Enabled.AutoSteal = not C.Enabled.AutoSteal
		if C.Enabled.AutoSteal then C.startAutoSteal() else C.stopAutoSteal() end
		if C.VisualSetters["Auto Steal"] then C.VisualSetters["Auto Steal"](C.Enabled.AutoSteal) end
		C.SaveConfig()
		
	elseif kc == C.KEYBINDS.ANTIRAGDOLL then
		C.Enabled.AntiRagdoll = not C.Enabled.AntiRagdoll
		if C.Enabled.AntiRagdoll then C.startAntiRagdoll() else C.stopAntiRagdoll() end
		if C.VisualSetters["Anti Ragdoll"] then C.VisualSetters["Anti Ragdoll"](C.Enabled.AntiRagdoll) end
