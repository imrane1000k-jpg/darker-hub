-- 1. SPEED SYSTEM (Auto Choose Normal vs Stealing)
local function updateSpeed()
    if not scriptActive or not Features.ThiefSpeed then 
        if speedConn then speedConn:Disconnect(); speedConn = nil end
        return 
    end
    
    if speedConn then return end -- Already running
    
    speedConn = RunService.Heartbeat:Connect(function()
        local c = Player.Character
        if not c then return end
        local h = c:FindFirstChild("HumanoidRootPart")
        if not h then return end
        local hum = c:FindFirstChildOfClass("Humanoid")
        local md = hum and hum.MoveDirection or Vector3.zero
        
        if md.Magnitude > 0.1 then
            -- Auto Choose Speed: Check if stealing attribute exists
            local isStealing = Player:GetAttribute("Stealing")
            local currentSpeed = isStealing and Values.StealingSpeedValue or Values.NormalSpeedValue
            
            h.AssemblyLinearVelocity = Vector3.new(md.X * currentSpeed, h.AssemblyLinearVelocity.Y, md.Z * currentSpeed)
        end
    end)
end

local function stopSpeed()
    if speedConn then 
        speedConn:Disconnect() 
        speedConn = nil 
    end
end

-- 2. AUTO LEFT / RIGHT (Simple Placeholder Logic for Integration)
-- Note: Full coordinate logic requires specific map data. This uses basic movement for demonstration.
local function startAutoLeft()
    if autoLeftConn then return end
    autoLeftConn = RunService.Heartbeat:Connect(function()
        if not Features.AutoLeft then return end
        local c = Player.Character
        if not c then return end
        local h = c:FindFirstChild("HumanoidRootPart")
        if h then
            h.CFrame = h.CFrame * CFrame.new(-0.5, 0, 0) -- Moves Left relative to look
        end
    end)
end
local function stopAutoLeft()
    if autoLeftConn then autoLeftConn:Disconnect(); autoLeftConn = nil end
end

local function startAutoRight()
