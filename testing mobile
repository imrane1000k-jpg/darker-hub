    function Hub.captureJumpPower()
        local c = Player.Character
        if c then
            local hum = c:FindFirstChildOfClass("Humanoid")
            if hum and hum.JumpPower > 0 then 
                Hub.Objects.OriginalJumpPower = hum.JumpPower 
            end
        end
    end
    
    task.spawn(function() Hub.captureJumpPower() end)
    Player.CharacterAdded:Connect(function() 
        task.wait(1) 
        Hub.captureJumpPower() 
    end)
    
    function Hub.setupGalaxyForce()
        pcall(function()
            local hrp = Hub.getHRP()
            if not hrp then return end
            
            if Hub.Objects.GalaxyVectorForce then Hub.Objects.GalaxyVectorForce:Destroy() end
            if Hub.Objects.GalaxyAttachment then Hub.Objects.GalaxyAttachment:Destroy() end
            
            Hub.Objects.GalaxyAttachment = Instance.new("Attachment", hrp)
            Hub.Objects.GalaxyVectorForce = Instance.new("VectorForce", hrp)
            Hub.Objects.GalaxyVectorForce.Attachment0 = Hub.Objects.GalaxyAttachment
            Hub.Objects.GalaxyVectorForce.ApplyAtCenterOfMass = true
            Hub.Objects.GalaxyVectorForce.RelativeTo = Enum.ActuatorRelativeTo.World
            Hub.Objects.GalaxyVectorForce.Force = Vector3.new(0, 0, 0)
        end)
    end
    
    function Hub.updateGalaxyForce()
        if not Hub.Objects.GalaxyEnabled or not Hub.Objects.GalaxyVectorForce then return end
        local c = Player.Character
        if not c then return end
        
        local mass = 0
        for _, p in ipairs(c:GetDescendants()) do 
            if p:IsA("BasePart") then mass = mass + p:GetMass() end 
        end
        
        local tg = Hub.Values.DEFAULT_GRAVITY * (Hub.Values.GalaxyGravityPercent / 100)
        Hub.Objects.GalaxyVectorForce.Force = Vector3.new(
            0, 
            mass * (Hub.Values.DEFAULT_GRAVITY - tg) * 0.95, 
            0
        )
    end
    
    function Hub.adjustGalaxyJump()
        pcall(function()
            local c = Player.Character
            local hum = c and c:FindFirstChildOfClass("Humanoid")
            if not hum then return end
            
            if not Hub.Objects.GalaxyEnabled then 
                hum.JumpPower = Hub.Objects.OriginalJumpPower
                return 
            end
            
            local ratio = math.sqrt(
                (Hub.Values.DEFAULT_GRAVITY * (Hub.Values.GalaxyGravityPercent / 100)) / 
                Hub.Values.DEFAULT_GRAVITY
            )
            hum.JumpPower = Hub.Objects.OriginalJumpPower * ratio
        end)
    end
    
    function Hub.doMiniHop()
        if not Hub.Objects.HopsEnabled then return end
        pcall(function()
            local c = Player.Character
            local hrp = c and c:FindFirstChild("HumanoidRootPart")
            local hum = c and c:FindFirstChildOfClass("Humanoid")
            if not hrp or not hum then return end
            
            if tick() - Hub.Objects.LastHopTime < Hub.Values.HOP_COOLDOWN then return end
            Hub.Objects.LastHopTime = tick()
            
            if hum.FloorMaterial == Enum.Material.Air then
                hrp.AssemblyLinearVelocity = Vector3.new(
                    hrp.AssemblyLinearVelocity.X, 
                    Hub.Values.HOP_POWER, 
                    hrp.AssemblyLinearVelocity.Z
                )
            end
        end)
    end
    
    function Hub.startGalaxy()
        Hub.Objects.GalaxyEnabled = true
        Hub.Objects.HopsEnabled = true
        Hub.setupGalaxyForce()
        Hub.adjustGalaxyJump()
    end
    
    function Hub.stopGalaxy()
        Hub.Objects.GalaxyEnabled = false
        Hub.Objects.HopsEnabled = false
        if Hub.Objects.GalaxyVectorForce then 
            Hub.Objects.GalaxyVectorForce:Destroy() 
            Hub.Objects.GalaxyVectorForce = nil 
        end
        if Hub.Objects.GalaxyAttachment then 
            Hub.Objects.GalaxyAttachment:Destroy() 
            Hub.Objects.GalaxyAttachment = nil 
        end
        Hub.adjustGalaxyJump()
    end
    
