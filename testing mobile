            if not (readfile and isfile and isfile(Hub.ConfigFileName)) then return end
            
            local ok, data = pcall(function()
                return HttpService:JSONDecode(readfile(Hub.ConfigFileName))
            end)
            
            if not ok or not data then return end
            
            -- Load enabled states
            for k, v in pairs(data) do
                if Hub.Enabled[k] ~= nil then Hub.Enabled[k] = v end
            end
            
            -- Load values
            for k, v in pairs(data) do
                if Hub.Values[k] ~= nil then Hub.Values[k] = v end
            end
            
            -- Load keybinds
            for key, codeName in pairs(data) do
                if key:match("^KEY_") then
                    local kbind = key:gsub("KEY_", "")
                    if Hub.KEYBINDS[kbind] then
                        local kc = Enum.KeyCode[codeName]
                        if kc then Hub.KEYBINDS[kbind] = kc end
