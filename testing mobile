    function Hub.startAutoPlayLeft()
        if Hub.AutoPlayLeftConnection then Hub.AutoPlayLeftConnection:Disconnect() end
        Hub.AutoPlayLeftPhase = 1
        Hub.AutoPlayLeftWait = false
        Hub.AutoPlayLeftWaitStart = 0
        
        local c = Player.Character
        local h = c and c:FindFirstChild("HumanoidRootPart")
        if h then
            local walkOri = h:FindFirstChild("AutoPlayOri")
            if not walkOri then
                local walkAtt = Instance.new("Attachment", h)
                walkAtt.Name = "AutoPlayAtt"
                walkOri = Instance.new("AlignOrientation", h)
                walkOri.Name = "AutoPlayOri"
                walkOri.Mode = Enum.OrientationAlignmentMode.OneAttachment
                walkOri.Attachment0 = walkAtt
                walkOri.MaxTorque = math.huge
                walkOri.Responsiveness = 200
            end
        end
        
        local seq = {Hub.POSITION_1, Hub.POSITION_2, Hub.POSITION_1, Hub.POSITION_LFINAL}
        
        Hub.AutoPlayLeftConnection = RunService.Heartbeat:Connect(function()
            if not Hub.Enabled.AutoPlayLeftEnabled then return end
            
            local char = Player.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            
            local wo = hrp:FindFirstChild("AutoPlayOri")
            
            if Hub.AutoPlayLeftWait then
                hrp.AssemblyLinearVelocity = Vector3.new(0, hrp.AssemblyLinearVelocity.Y, 0)
                if tick() - Hub.AutoPlayLeftWaitStart >= Hub.Values.AutoPlayWaitTime then
                    Hub.AutoPlayLeftWait = false
                    Hub.AutoPlayLeftPhase = Hub.AutoPlayLeftPhase + 1
                end
                return
            end
            
            if Hub.AutoPlayLeftPhase <= #seq then
                local targetPos = seq[Hub.AutoPlayLeftPhase]
                local dist = (Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z) - hrp.Position).Magnitude
                
                if dist < 2 then
                    hrp.AssemblyLinearVelocity = Vector3.new(0, hrp.AssemblyLinearVelocity.Y, 0)
                    Hub.AutoPlayLeftPhase = Hub.AutoPlayLeftPhase + 1
                else
                    local flatDir = Vector3.new(targetPos.X - hrp.Position.X, 0, targetPos.Z - hrp.Position.Z)
                    local moveDir = flatDir.Unit
                    if wo then 
                        wo.CFrame = CFrame.lookAt(hrp.Position, Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z)) 
                    end
                    
                    local spd = (Hub.AutoPlayLeftPhase == 4) and Hub.Values.AutoPlayReturnSpeed or Hub.Values.AutoLeftSpeed
                    hrp.AssemblyLinearVelocity = Vector3.new(
                        moveDir.X * spd, 
                        hrp.AssemblyLinearVelocity.Y, 
                        moveDir.Z * spd
                    )
                end
            else
                hrp.AssemblyLinearVelocity = Vector3.new(0, hrp.AssemblyLinearVelocity.Y, 0)
                Hub.Enabled.AutoPlayLeftEnabled = false
                if Hub.VisualSetters.AutoPlayLeftEnabled then 
                    Hub.VisualSetters.AutoPlayLeftEnabled(false) 
                end
                if Hub.AutoPlayLeftConnection then 
                    Hub.AutoPlayLeftConnection:Disconnect() 
                    Hub.AutoPlayLeftConnection = nil 
                end
                local wa = hrp:FindFirstChild("AutoPlayAtt")
                if wo then wo:Destroy() end
                if wa then wa:Destroy() end
                Hub.faceCam(0)
            end
        end)
