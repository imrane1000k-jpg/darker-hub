	elseif kc == C.KEYBINDS.INFJUMP then
		C.Enabled.InfJump = not C.Enabled.InfJump
		if C.VisualSetters["Infinite Jump"] then C.VisualSetters["Infinite Jump"](C.Enabled.InfJump) end
