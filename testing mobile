-- ─── KEYBINDS (PC & Mobile) ───────────────────────────────────────
local Keybinds = {
    ThiefSpeed = Enum.KeyCode.F2,
    AutoLeft = Enum.KeyCode.Z,
    AutoRight = Enum.KeyCode.C,
    Lock = Enum.KeyCode.X,
    TPDown = Enum.KeyCode.G,
    Drop = Enum.KeyCode.V
}

UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    
    if input.KeyCode == Keybinds.ThiefSpeed then
        Features.ThiefSpeed = not Features.ThiefSpeed
        if Features.ThiefSpeed then updateSpeed() else stopSpeed() end
    elseif input.KeyCode == Keybinds.AutoLeft then
        Features.AutoLeft = not Features.AutoLeft
        if Features.AutoLeft then startAutoLeft() else stopAutoLeft() end
    elseif input.KeyCode == Keybinds.AutoRight then
        Features.AutoRight = not Features.AutoRight
        if Features.AutoRight then startAutoRight() else stopAutoRight() end
    elseif input.KeyCode == Keybinds.Lock then
        Features.Lock = not Features.Lock
        toggleLock()
    elseif input.KeyCode == Keybinds.TPDown then
        doTPDown()
    elseif input.KeyCode == Keybinds.Drop then
         local c = Player.Character
        if c then
            local h = c:FindFirstChild("HumanoidRootPart")
            if h then h.AssemblyLinearVelocity = Vector3.new(0, -50, 0) end
        end
    end
end)

