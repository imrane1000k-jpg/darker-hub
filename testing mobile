            unwalkEnabled = not unwalkEnabled
            if unwalkEnabled then startUnwalk() else stopUnwalk() end
            if toggleSetters["Unwalk"] then toggleSetters["Unwalk"](unwalkEnabled) end
            saveConfig()
        end
    end)

