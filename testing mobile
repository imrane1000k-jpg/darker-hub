                if nm then nm:Destroy() end
            end
        end
        for _, c in ipairs(C.EspConnections) do c:Disconnect() end
        C.EspConnections = {}
    else
        for _, p in ipairs(C.Players:GetPlayers()) do
            C.createESP(p)
            table.insert(C.EspConnections, p.CharacterAdded:Connect(function() task.wait(0.1); if C.espEnabled then C.createESP(p) end end))
