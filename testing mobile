	elseif kc == C.KEYBINDS.OPTIMIZER then
		C.Enabled.Optimizer = not C.Enabled.Optimizer
		if C.Enabled.Optimizer then C.enableOptimizer() else C.disableOptimizer() end
		if C.VisualSetters["Optimizer+XRay"] then C.VisualSetters["Optimizer+XRay"](C.Enabled.Optimizer) end
		C.SaveConfig()
	end
end)

C.UserInputService.InputBegan:Connect(function(input) if input.KeyCode==Enum.KeyCode.Space then C.SpaceHeld=true end end)
C.UserInputService.InputEnded:Connect(function(input) if input.KeyCode==Enum.KeyCode.Space then C.SpaceHeld=false end end)

local function setupChar(c)
	if C.GalaxyEnabled then C.stopGalaxy(); C.startGalaxy() end
	if C.Enabled.AntiRagdoll then C.stopAntiRagdoll(); C.startAntiRagdoll() end
	if C.Enabled.SpinBot then C.stopSpinBot(); C.startSpinBot() end
	if C.Enabled.ESP then C.toggleESP(true) end
	if C.Enabled.BatAimbot then C.stopBatAimbot(); C.startBatAimbot() end
	if C.Enabled.Unwalk then C.startUnwalk() end
end
if C.Player.Character then setupChar(C.Player.Character) end
C.Player.CharacterAdded:Connect(function(c) task.wait(0.5); setupChar(c) end)

-- Initial Loads
if C.Enabled.ESP then C.toggleESP(true) end
C.hookFOV()
if C.Enabled.SpinBot then C.startSpinBot() end
if C.Enabled.AntiRagdoll then C.startAntiRagdoll() end
if C.Enabled.Unwalk then C.startUnwalk() end
if C.Enabled.BatAimbot then C.startBatAimbot() end
if C.Enabled.AutoSteal then C.startAutoSteal() end
if C.GalaxyEnabled then C.startGalaxy() end
if C.Enabled.Optimizer then C.enableOptimizer() end

end)
