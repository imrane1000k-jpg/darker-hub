local function setupChar(c)
    gChar = c; gHum = c:WaitForChild("Humanoid", 5); gHrp = c:WaitForChild("HumanoidRootPart", 5)
    if not gHum or not gHrp then return end
    task.wait(0.5)
    if C.GalaxyEnabled then C.stopGalaxy(); C.startGalaxy() end
    if C.antiRagdollEnabled then C.stopAntiRagdoll(); C.startAntiRagdoll() end
    if C.spinBotEnabled then C.stopSpinBot(); C.startSpinBot() end
    if C.espEnabled then C.toggleESP(true) end
    if C.batAimbotEnabled then C.stopBatAimbot(); C.startBatAimbot() end
    if C.unwalkEnabled then C.startUnwalk() end
    if C.autoStealEnabled then C.startAutoSteal() end
    C.applyFOV()
end
