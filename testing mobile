function C.isMyBase(plotName)
    local plots = workspace:FindFirstChild("Plots")
    local sign = plots and plots:FindFirstChild(plotName) and plots[plotName]:FindFirstChild("PlotSign")
    return sign and sign:FindFirstChild("YourBase") and sign.YourBase:IsA("BillboardGui") and sign.YourBase.Enabled
end

function C.scanPlot(plot)
    if not plot or not plot:IsA("Model") then return end
    if C.isMyBase(plot.Name) then return end
    local podiums = plot:FindFirstChild("AnimalPodiums")
    if not podiums then return end
    for _, pod in ipairs(podiums:GetChildren()) do
        if pod:IsA("Model") and pod:FindFirstChild("Base") then
            table.insert(C.animalCache, {plot=plot.Name, slot=pod.Name, worldPosition=pod:GetPivot().Position, uid=plot.Name.."_"..pod.Name})
        end
    end
end

function C.findPromptForAnimal(ad)
    if not ad then return nil end
    local cp = C.promptCache[ad.uid]
    if cp and cp.Parent then return cp end
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil end
    local plot = plots:FindFirstChild(ad.plot)
    if not plot then return nil end
    local pods = plot:FindFirstChild("AnimalPodiums")
    if not pods then return nil end
    local pod = pods:FindFirstChild(ad.slot)
    if not pod then return nil end
    local base = pod:FindFirstChild("Base")
    if not base then return nil end
    local sp = base:FindFirstChild("Spawn")
    if not sp then return nil end
    local att = sp:FindFirstChild("PromptAttachment")
    if not att then return nil end
    for _, p in ipairs(att:GetChildren()) do
        if p:IsA("ProximityPrompt") then C.promptCache[ad.uid] = p; return p end
    end
end

function C.buildCallbacks(prompt)
    if C.stealCache[prompt] then return end
    local data = {hold = {}, trigger = {}, ready = true}
    pcall(function()
        if getconnections then
            for _, c in ipairs(getconnections(prompt.PromptButtonHoldBegan)) do if type(c.Function) == "function" then table.insert(data.hold, c.Function) end end
            for _, c in ipairs(getconnections(prompt.Triggered)) do if type(c.Function) == "function" then table.insert(data.trigger, c.Function) end end
        end
    end)
    if #data.hold > 0 or #data.trigger > 0 then C.stealCache[prompt] = data end
end

function C.executeSteal(prompt)
    local data = C.stealCache[prompt]
    if not data or not data.ready then return false end
    data.ready = false; C.isStealing = true; C.stealStartTime = tick()
    if C.ProgressLabel then C.ProgressLabel.Text = "STEALING..." end
    if C.progressConn then C.progressConn:Disconnect() end
    C.progressConn = C.RunService.Heartbeat:Connect(function()
        if not C.isStealing then C.progressConn:Disconnect(); return end
        local prog = math.clamp((tick() - C.stealStartTime) / C.Values.STEAL_DURATION, 0, 1)
        if C.ProgressBarFill then C.ProgressBarFill.Size = UDim2.new(prog, 0, 1, 0) end
        if C.ProgressPctLabel then C.ProgressPctLabel.Text = math.floor(prog * 100) .. "%" end
    end)
    task.spawn(function()
        for _, f in ipairs(data.hold) do task.spawn(f) end
        task.wait(C.Values.STEAL_DURATION)
        for _, f in ipairs(data.trigger) do task.spawn(f) end
        if C.progressConn then C.progressConn:Disconnect() end
        if C.ProgressLabel then C.ProgressLabel.Text = "READY" end
        if C.ProgressPctLabel then C.ProgressPctLabel.Text = "" end
        if C.ProgressBarFill then C.ProgressBarFill.Size = UDim2.new(0, 0, 1, 0) end
        data.ready = true; C.isStealing = false
    end)
    return true
end

function C.nearestAnimal()
    local h = gHrp
    if not h then return nil end
    local best, bestD = nil, math.huge
    for _, ad in ipairs(C.animalCache) do
        if not C.isMyBase(ad.plot) and ad.worldPosition then
            local d = (h.Position - ad.worldPosition).Magnitude
            if d < bestD then bestD = d; best = ad end
        end
    end
    return best
end

function C.startAutoSteal()
    if C.Connections.autoSteal then return end
    C.Connections.autoSteal = C.RunService.Heartbeat:Connect(function()
        if not C.Enabled.AutoSteal or C.isStealing then return end
        local target = C.nearestAnimal()
        if not target then return end
        local h = gHrp
        if not h then return end
        if (h.Position - target.worldPosition).Magnitude > C.Values.STEAL_RADIUS then return end
        local prompt = C.promptCache[target.uid]
        if not prompt or not prompt.Parent then prompt = C.findPromptForAnimal(target) end
        if prompt then C.buildCallbacks(prompt); C.executeSteal(prompt) end
    end)
    task.spawn(function()
        task.wait(2)
        local plots = workspace:WaitForChild("Plots", 10)
        if not plots then return end
        for _, plot in ipairs(plots:GetChildren()) do if plot:IsA("Model") then C.scanPlot(plot) end end
        plots.ChildAdded:Connect(function(plot) if plot:IsA("Model") then task.wait(0.5); C.scanPlot(plot) end end)
    end)
end
function C.stopAutoSteal()
    if C.Connections.autoSteal then C.Connections.autoSteal:Disconnect() C.Connections.autoSteal = nil end
    C.isStealing = false
    if C.progressConn then C.progressConn:Disconnect() end
    if C.ProgressBarFill then C.ProgressBarFill.Size = UDim2.new(0, 0, 1, 0) end
    if C.ProgressLabel then C.ProgressLabel.Text = "READY" end
end

