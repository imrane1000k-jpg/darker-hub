        if C.ProgressPctLabel then C.ProgressPctLabel.Text = math.floor(prog * 100) .. "%" end
    end)
    task.spawn(function()
        for _, f in ipairs(data.hold) do task.spawn(f) end
        task.wait(C.Values.STEAL_DURATION)
        for _, f in ipairs(data.trigger) do task.spawn(f) end
        if C.progressConn then C.progressConn:Disconnect() end
        if C.ProgressLabel then C.ProgressLabel.Text = "READY" end
        if C.ProgressPctLabel then C.ProgressPctLabel.Text = "" end
        if C.ProgressBarFill then C.ProgressBarFill.Size = UDim2.new(0, 0, 1, 0) end
