    local btnDR, bsDR = makePBtn("DROP", "", 4)
    local btnTP, bsTP = makePBtn("TP", "DOWN", 5)

    local pState = { AAL = false, AAR = false, LK = false }

    local function mutualOff(keep)
        local map = { AAL = { btnAAL, bsAAL }, AAR = { btnAAR, bsAAR }, LK = { btnLK, bsLK } }
        for k, v in pairs(map) do
            if k ~= keep and pState[k] then
                pState[k] = false
                setPH(v[1], v[2], false)
                if k == "AAL" then
                    autoLOn = false
                    stopAutoL()
                    if toggleSetters["Auto Left"] then toggleSetters["Auto Left"](false) end
                elseif k == "AAR" then
                    autoROn = false
                    stopAutoR()
                    if toggleSetters["Auto Right"] then toggleSetters["Auto Right"](false) end
                elseif k == "LK" then
                    stopBatAimbot()
                    if toggleSetters["Lock (Bat Aimbot)"] then toggleSetters["Lock (Bat Aimbot)"](false) end
                end
            end
        end
    end

