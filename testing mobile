    function Hub.startAutoL()
        if Hub.autoLConn then Hub.autoLConn:Disconnect() end
        Hub.autoLPhase = 1
        local pts = {Hub.FAP_L1, Hub.FAP_L2, Hub.FAP_L3, Hub.FAP_L4, Hub.FAP_L5}
        
        Hub.autoLConn = RunService.Heartbeat:Connect(function()
            if not Hub.autoLOn then return end
            local gHrp = Hub.getHRP()
            local gHum = Hub.getHum()
            if not gHrp or not gHum then return end
            
            local ph = Hub.autoLPhase
            local tgt = pts[ph]
            local spd = ph >= 3 and Hub.getCarrySpeed() or Hub.getAutoSpeed()
            local flat = Vector3.new(tgt.X - gHrp.Position.X, 0, tgt.Z - gHrp.Position.Z)
            
            if flat.Magnitude < 1 then
                if ph == 5 then
                    gHum:Move(Vector3.zero, false)
                    gHrp.AssemblyLinearVelocity = Vector3.zero
                    Hub.autoLOn = false
                    Hub.stopAutoL()
                    local info = Hub.mobBtnRefs["AUTO L"]
                    if info then 
                        info.btn.BackgroundColor3 = Color3.fromRGB(8, 8, 8)
                        info.bs.Color = Color3.fromRGB(40, 40, 50)
                        info.bs.Transparency = 0.2
                        info.state = false 
                    end
                    if Hub.toggleSetters["Auto Left"] then 
                        Hub.toggleSetters["Auto Left"](false) 
                    end
                    return
                elseif ph == 2 then
                    gHum:Move(Vector3.zero, false)
                    gHrp.AssemblyLinearVelocity = Vector3.zero
                    task.wait(0.05)
                    Hub.autoLPhase = 3
                    return
                else
                    Hub.autoLPhase = ph + 1
                    return
                end
            end
            
            local md = flat.Unit
            gHum:Move(md, false)
            gHrp.AssemblyLinearVelocity = Vector3.new(
