local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- UI
local Gui = Instance.new("ScreenGui")
Gui.Name = "X"
Gui.Parent = game:GetService("CoreGui")
Gui.ResetOnSpawn = false
Gui.IgnoreGuiInset = true

local Main = Instance.new("Frame")
Main.Parent = Gui
Main.BackgroundColor3 = Color3.fromRGB(18, 18, 20)
Main.BorderSizePixel = 0

Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 10)
local Stroke = Instance.new("UIStroke", Main)
Stroke.Color = Color3.fromRGB(50, 50, 55)
Stroke.Thickness = 1

-- Top Bar (Drag)
local Bar = Instance.new("TextButton", Main)
Bar.Size = UDim2.new(1, 0, 0, 22)
Bar.BackgroundColor3 = Color3.fromRGB(28, 28, 30)
Bar.Font = Enum.Font.GothamBold
Bar.Text = "DESYNC"
Bar.TextColor3 = Color3.fromRGB(255, 255, 255)
Bar.TextSize = 11
Bar.AutoButtonColor = false

Instance.new("UICorner", Bar).CornerRadius = UDim.new(0, 10)
local Fix = Instance.new("Frame", Bar)
Fix.Size = UDim2.new(1, 0, 0, 8)
Fix.Position = UDim2.new(0, 0, 1, -8)
Fix.BackgroundColor3 = Color3.fromRGB(28, 28, 30)
Fix.BorderSizePixel = 0

-- The Only Button (Toggle + Instant Reset)
local Btn = Instance.new("TextButton", Main)
Btn.Name = "Btn"
Btn.Size = UDim2.new(1, -14, 0, 32)
Btn.Position = UDim2.new(0, 7, 0, 27)
Btn.BackgroundColor3 = Color3.fromRGB(35, 35, 38)
Btn.Font = Enum.Font.GothamBold
Btn.TextColor3 = Color3.fromRGB(255, 70, 70)
Btn.TextSize = 13
Btn.Text = "DISABLED"
Btn.AutoButtonColor = false

Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)
local BS = Instance.new("UIStroke", Btn)
BS.Color = Color3.fromRGB(60, 60, 65)

-- Scale
local function scale()
    local s = workspace.CurrentCamera.ViewportSize.X
    if s < 1000 or UserInputService.TouchEnabled then
        Main.Size = UDim2.new(0, 150, 0, 75)
        Main.Position = UDim2.new(0.5, -75, 0.5, -37.5)
    else
        Main.Size = UDim2.new(0, 130, 0, 68)
        Main.Position = UDim2.new(0.5, -65, 0.5, -34)
    end
end
scale()

-- Drag
local drag, start, pos
Bar.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        drag = true; start = i.Position; pos = Main.Position
        i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then drag = false end end)
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if drag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
        Main.Position = UDim2.new(pos.X.Scale, pos.X.Offset+(i.Position-start).X, pos.Y.Scale, pos.Y.Offset+(i.Position-start).Y)
    end
end)

-- Logic
local on = false
local function upd(s)
    on = s
    if s then
        TweenService:Create(Btn, TweenInfo.new(0.25), {BackgroundColor3=Color3.fromRGB(25,45,35), TextColor3=Color3.fromRGB(80,255,140)}):Play()
        Btn.Text = "ENABLED"
        BS.Color = Color3.fromRGB(40,110,75)
    else
        TweenService:Create(Btn, TweenInfo.new(0.25), {BackgroundColor3=Color3.fromRGB(35,35,38), TextColor3=Color3.fromRGB(255,70,70)}):Play()
        Btn.Text = "DISABLED"
        BS.Color = Color3.fromRGB(60,60,65)
    end
end

Btn.MouseButton1Click:Connect(function()
    local newState = not on
    upd(newState)
    
    pcall(function()
        raknet.desync(newState)
        
        -- INSTANT RESET HAPPENS HERE AUTOMATICALLY
        LocalPlayer:LoadCharacter() 
    end)
end)

upd(false)
