-- Size Logic (Small & Mobile Friendly)
local function resize()
    local s = workspace.CurrentCamera.ViewportSize.X
    local m = s < 1000 or UserInputService.TouchEnabled
    if m then
        Main.Size = UDim2.new(0, 160, 0, 115)
        Main.Position = UDim2.new(0.5, -80, 0.5, -57.5)
    else
        Main.Size = UDim2.new(0, 140, 0, 105)
        Main.Position = UDim2.new(0.5, -70, 0.5, -52.5)
    end
end
resize()

-- Dragging
local drag, start, pos
Bar.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        drag = true
        start = i.Position
        pos = Main.Position
        i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then drag = false end end)
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if drag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
        Main.Position = UDim2.new(pos.X.Scale, pos.X.Offset + (i.Position-start).X, pos.Y.Scale, pos.Y.Offset + (i.Position-start).Y)
    end
end)

-- Logic
local on = false
local function upd(s)
    on = s
    if s then
        TweenService:Create(Tog, TweenInfo.new(0.2), {BackgroundColor3=Color3.fromRGB(25,45,35), TextColor3=Color3.fromRGB(80,255,140)}):Play()
        Tog.Text = "ON"
        TS.Color = Color3.fromRGB(40,110,75)
    else
        TweenService:Create(Tog, TweenInfo.new(0.2), {BackgroundColor3=Color3.fromRGB(35,35,38), TextColor3=Color3.fromRGB(255,80,80)}):Play()
        Tog.Text = "OFF"
        TS.Color = Color3.fromRGB(60,60,65)
    end
end

Tog.MouseButton1Click:Connect(function()
    upd(not on)
    pcall(function()
        raknet.desync(on)
        if on then
            local h = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
            if h then h.Health = 0 end
        end
    end)
end)

Res.MouseButton1Click:Connect(function()
    TweenService:Create(Res, TweenInfo.new(0.1), {BackgroundColor3=Color3.fromRGB(80,40,40)}):Play()
    wait(0.1)
    TweenService:Create(Res, TweenInfo.new(0.2), {BackgroundColor3=Color3.fromRGB(40,25,25)}):Play()
    
    pcall(function()
        raknet.desync(false)
        upd(false)
        LocalPlayer:LoadCharacter() -- Instant full reset
    end)
end)

upd(false)
