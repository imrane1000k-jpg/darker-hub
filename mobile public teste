        if State.AutoDestroyTurrets and LocalPlayer:GetAttribute("Stealing") ~= true then
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then continue end
            
            for _, inst in ipairs(Workspace:GetDescendants()) do
                if inst.Name:match("^Sentry_") then
                    local root = inst:IsA("BasePart") and inst or inst:FindFirstChildWhichIsA("BasePart", true)
                    if root then
                        local dist = (hrp.Position - root.Position).Magnitude
                        if dist < 120 then
                            -- Make transparent
                            for _, d in ipairs(inst:GetDescendants()) do
                                if d:IsA("BasePart") and d ~= inst then 
                                    d.Transparency = 0.5 
                                    d.CanCollide = false 
                                end
                                if d:IsA("BillboardGui") and d.Name ~= "SentryLabel" then 
                                    d:Destroy() 
                                end
                            end
                            
                            -- Move close and use bat
                            local offset = hrp.CFrame.LookVector * 3
                            if inst:IsA("Model") then
                                inst:PivotTo(CFrame.new(hrp.Position + offset))
                            elseif inst:IsA("BasePart") then
                                inst.CFrame = CFrame.new(hrp.Position + offset)
