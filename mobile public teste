local function Notify(title, text, color)
    local gui = Instance.new("ScreenGui", PlayerGui)
    gui.Name = "RH_Notif_"..tick(); gui.ResetOnSpawn = false
    
    local frame = Instance.new("Frame", gui)
    frame.Size = UDim2.new(0, 300, 0, 55)
    frame.Position = UDim2.new(0.5, -150, 0, -70)
    frame.BackgroundColor3 = Theme.Surface
    frame.BorderSizePixel = 0
    Instance.new("UICorner', frame).CornerRadius = UDim.new(0, 12)
    
    local stroke = Instance.new("UIStroke", frame)
    stroke.Color = color or Theme.Accent1; stroke.Thickness = 1.5
    
    local titleLbl = Instance.new("TextLabel", frame)
    titleLbl.Size = UDim2.new(1, -16, 0, 24); titleLbl.Position = UDim2.new(0, 8, 0, 6)
    titleLbl.BackgroundTransparency = 1; titleLbl.Text = title
    titleLbl.Font = Enum.Font.GothamBlack; titleLbl.TextSize = 14
    titleLbl.TextColor3 = Theme.Accent1; titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    
    local textLbl = Instance.new("TextLabel", frame)
    textLbl.Size = UDim2.new(1, -16, 0, 22); textLbl.Position = UDim2.new(0, 8, 0, 28)
    textLbl.BackgroundTransparency = 1; textLbl.Text = text or ""
    textLbl.Font = Enum.Font.GothamMedium; textLbl.TextSize = 12
    textLbl.TextColor3 = Theme.TextSecondary; textLbl.TextXAlignment = Enum.TextXAlignment.Left
    
    TweenService:Create(frame, TweenInfo.new(0.4, Enum.EasingStyle.Quart), {Position = UDim2.new(0.5, -150, 0, 85)}):Play()
    task.delay(2.8, function()
        TweenService:Create(frame, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -150, 0, -70)}):Play()
        task.wait(0.35) if gui then gui:Destroy() end
    end)
end

local function MakeDraggable(handle, frame)
    local dragging, dragInput, startPos, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragInput = input; startPos = frame.Position; startPos = input.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    handle.InputChanged:Connect(function(input) if input == dragInput and dragging then dragInput = input end end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            frame.Position = startPos + (input.Position - startPos)
        end
    end)
end

