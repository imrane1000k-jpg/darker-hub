                if hrp and plotPart then
                    if not PlotBeam or not PlotBeam.Parent then
                        PlotAtt0 = Instance.new("Attachment", hrp)
                        PlotAtt1 = Instance.new("Attachment", plotPart)
                        
                        PlotBeam = Instance.new("Beam", hrp)
                        PlotBeam.Attachment0 = PlotAtt0
                        PlotBeam.Attachment1 = PlotAtt1
                        PlotBeam.Width0 = 0.7
                        PlotBeam.Width1 = 0.7
                        PlotBeam.FaceCamera = true
                        PlotBeam.LightEmission = 1
                        
                        -- Rainbow animation
                        task.spawn(function()
                            while PlotBeam and PlotBeam.Parent do
                                local hue = (tick() % 3) / 3
                                PlotBeam.Color = ColorSequence.new(Color3.fromHSV(hue, 1, 1))
                                task.wait(0.04)
                            end
                        end)
                    end
                end
            else
                -- Cleanup
                if PlotBeam then PlotBeam:Destroy() PlotBeam = nil end
                if PlotAtt0 then PlotAtt0:Destroy() PlotAtt0 = nil end
                if PlotAtt1 then PlotAtt1:Destroy() PlotAtt1 = nil end
            end
        else
            -- Cleanup when disabled
            if PlotBeam then PlotBeam:Destroy() PlotBeam = nil end
            if PlotAtt0 then PlotAtt0:Destroy() PlotAtt0 = nil end
            if PlotAtt1 then PlotAtt1:Destroy() PlotAtt1 = nil end
        end
    end
end)

