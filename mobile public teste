-- BEAST PET TRACER (Beam to best pet)
-- ═════════════════════════════════════════════════════════════════
local BeastBeam, BeastAtt0, BeastAtt1 = nil, nil, nil

task.spawn(function()
    while true do
        task.wait(2)
        if State.TracerEnabled then
            local plots = Workspace:FindFirstChild("Plots")
            if not plots then continue end
            
            local bestPet = nil
            local bestValue = 0
            
            for _, plot in ipairs(plots:GetChildren()) do
                local podiums = plot:FindFirstChild("AnimalPodiums")
                if podiums then
                    for _, pod in ipairs(podiums:GetChildren()) do
                        local spawn = pod:FindFirstChild("Base") and pod.Base:FindFirstChild("Spawn")
                        if spawn then
                            local att = spawn:FindFirstChild("Attachment")
                            local oh = att and att:FindFirstChild("AnimalOverhead")
                            if oh then
                                local genLbl = oh:FindFirstChild("Generation")
                                if genLbl then
                                    local txt = genLbl.Text
                                    local num = txt:match("(%d+%.?%d*)")
                                    if num and tonumber(num) then
                                        local val = tonumber(num)
                                        if val > bestValue then
                                            bestValue = val
                                            bestPet = spawn
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
            
            if bestPet then
                local char = LocalPlayer.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                
                if hrp and bestPet and bestPet.Parent then
                    if not BeastBeam or not BeastBeam.Parent or BeastAtt1.Parent ~= bestPet then
                        if BeastBeam then BeastBeam:Destroy() end
                        if BeastAtt0 then BeastAtt0:Destroy() end
                        if BeastAtt1 then BeastAtt1:Destroy() end
                        
                        BeastAtt0 = Instance.new("Attachment", hrp)
                        BeastAtt1 = Instance.new("Attachment", bestPet)
                        
                        BeastBeam = Instance.new("Beam", hrp)
                        BeastBeam.Attachment0 = BeastAtt0
                        BeastBeam.Attachment1 = BeastAtt1
                        BeastBeam.Width0 = 1
                        BeastBeam.Width1 = 1
                        BeastBeam.FaceCamera = true
                        BeastBeam.LightEmission = 1
                        BeastBeam.Color = ColorSequence.new(Color3.fromHSV(0, 1, 1)) -- Red
                        
                        -- Pulse animation
                        task.spawn(function()
                            while BeastBeam and BeastBeam.Parent do
                                for h = 0, 1, 0.02 do
                                    if not BeastBeam or not BeastBeam.Parent then break end
                                    BeastBeam.Color = ColorSequence.new(Color3.fromHSV(h, 1, 1))
                                    task.wait(0.03)
                                end
                                for h = 1, 0, -0.02 do
                                    if not BeastBeam or not BeastBeam.Parent then break end
                                    BeastBeam.Color = ColorSequence.new(Color3.fromHSV(h, 1, 1))
                                    task.wait(0.03)
                                end
                            end
                        end)
                    end
                end
            else
                if BeastBeam then BeastBeam:Destroy() BeastBeam = nil end
                if BeastAtt0 then BeastAtt0:Destroy() BeastAtt0 = nil end
                if BeastAtt1 then BeastAtt1:Destroy() BeastAtt1 = nil end
            end
        else
            if BeastBeam then BeastBeam:Destroy() BeastBeam = nil end
            if BeastAtt0 then BeastAtt0:Destroy() BeastAtt0 = nil end
            if BeastAtt1 then BeastAtt1:Destroy() BeastAtt1 = nil end
        end
    end
end)

