-- HELPER: Create Toggle Switch
-- ═════════════════════════════════════════════════════════════════
local function CreateToggle(parent, labelText, callback, defaultState)
    defaultState = defaultState or false
    
    local container = Instance.new("Frame", parent)
    container.Size = UDim2.new(1, 0, 0, 38)
    container.BackgroundTransparency = 1
    
    -- Label
    local label = Instance.new("TextLabel", container)
    label.Size = UDim2.new(0.65, 0, 1, 0); label.Position = UDim2.new(0, 4, 0, 0)
    label.BackgroundTransparency = 1; label.Text = labelText
    label.Font = Enum.Font.GothamMedium; label.TextSize = 14
    label.TextColor3 = Theme.TextPrimary; label.TextXAlignment = Enum.TextXAlignment.Left
    
    -- Toggle Background
    local toggleBg = Instance.new("Frame", container)
    toggleBg.Size = UDim2.new(0, 46, 0, 24)
    toggleBg.Position = UDim2.new(1, -50, 0.5, -12)
    toggleBg.BackgroundColor3 = defaultState and Theme.Success or Theme.SurfaceLight
    Instance.new("UICorner', toggleBg).CornerRadius = UDim.new(1, 12)
    
    -- Toggle Dot
    local dot = Instance.new("Frame", toggleBg)
    dot.Size = UDim2.new(0, 18, 0, 18)
    dot.Position = defaultState and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
    dot.BackgroundColor3 = Color3.fromRGB(255,255,255)
    Instance.new("UICorner', dot).CornerRadius = UDim.new(1, 99)
    
    -- Button
    local btn = Instance.new("TextButton", toggleBg)
    btn.Size = UDim2.new(1, 0, 1, 0); btn.BackgroundTransparency = 1; btn.Text = ""
    
    local isOn = defaultState
    
    btn.MouseButton1Click:Connect(function()
        isOn = not isOn
        callback(isOn)
        
        -- Animate
        TweenService:Create(dot, TweenInfo.new(0.2), {Position = isOn and UDim2.new(1,-21,0.5,-9) or UDim2.new(0,3,0.5,-9)}):Play()
        TweenService:Create(toggleBg, TweenInfo.new(0.2), {BackgroundColor3 = isOn and Theme.Success or Theme.SurfaceLight}):Play()
    end)
    
    return {
        SetState = function(state)
            isOn = state
            TweenService:Create(dot, TweenInfo.new(0.15), {Position = state and UDim2.new(1,-21,0.5,-9) or UDim2.new(0,3,0.5,-9)}):Play()
            TweenService:Create(toggleBg, TweenInfo.new(0.15), {BackgroundColor3 = state and Theme.Success or Theme.SurfaceLight}):Play()
        end,
        GetState = function() return isOn end
    }
end

