-- ─── 🔧 FEATURE LOGIC: THIEF SPEED ────────────────────────────────
local function startSpeedWhileStealing()
    if speedWhileStealingConn then return end
    speedWhileStealingConn = RunService.Heartbeat:Connect(function()
        if not scriptActive or not Features.ThiefSpeed or not Player:GetAttribute("Stealing") then return end
        local c = Player.Character
        if not c then return end
        local h = c:FindFirstChild("HumanoidRootPart")
        if not h then return end
        local hum = c:FindFirstChildOfClass("Humanoid")
        local md = hum and hum.MoveDirection or Vector3.zero
        if md.Magnitude > 0.1 then
            h.AssemblyLinearVelocity = Vector3.new(md.X * Values.StealingSpeedValue, h.AssemblyLinearVelocity.Y, md.Z * Values.StealingSpeedValue)
        end
    end)
end

local function stopSpeedWhileStealing()
    if speedWhileStealingConn then 
        speedWhileStealingConn:Disconnect() 
        speedWhileStealingConn = nil 
    end
end

-- ─── 🎛️ UI ELEMENTS (Toggle + Slider) ─────────────────────────────
local function makeToggle(parent, labelText, featureName)
    local frame = Instance.new("Frame", parent)
    frame.Size = UDim2.new(1, -16 * guiScale, 0, 40 * guiScale)
    frame.Position = UDim2.new(0, 8 * guiScale, 0, 10 * guiScale)
    frame.BackgroundColor3 = COLOR_BG_ROW
    frame.BackgroundTransparency = 0.4
    frame.BorderSizePixel = 0
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6 * guiScale)
    
    local fStroke = Instance.new("UIStroke", frame)
    fStroke.Thickness = 1.5 * guiScale
    fStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    fStroke.Color = COLOR_ACCENT

    local lbl = Instance.new("TextLabel", frame)
    lbl.Size = UDim2.new(0.6, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = labelText
    lbl.TextColor3 = COLOR_DIM
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 12 * guiScale
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Position = UDim2.new(0, 10, 0, 0)

    local bg = Instance.new("Frame", frame)
    bg.Size = UDim2.new(0, 40 * guiScale, 0, 20 * guiScale)
    bg.Position = UDim2.new(1, -50 * guiScale, 0.5, -10 * guiScale)
    bg.BackgroundColor3 = COLOR_OFF
    bg.ZIndex = 4
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)

    local circle = Instance.new("Frame", bg)
    circle.Size = UDim2.new(0, 16 * guiScale, 0, 16 * guiScale)
    circle.Position = UDim2.new(0, 2 * guiScale, 0.5, -8 * guiScale)
    circle.BackgroundColor3 = Color3.new(0.8, 0.8, 0.9)
    circle.ZIndex = 5
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)

    local isOn = false
    
    local function updateVisual(state)
        isOn = state
        if isOn then
            TweenService:Create(bg, TweenInfo.new(0.2), {BackgroundColor3 = COLOR_ACCENT}):Play()
            TweenService:Create(circle, TweenInfo.new(0.2), {Position = UDim2.new(1,-18*guiScale,0.5,-8*guiScale)}):Play()
            lbl.TextColor3 = COLOR_GLOW
        else
            TweenService:Create(bg, TweenInfo.new(0.2), {BackgroundColor3 = COLOR_OFF}):Play()
            TweenService:Create(circle, TweenInfo.new(0.2), {Position = UDim2.new(0,2*guiScale,0.5,-8*guiScale)}):Play()
            lbl.TextColor3 = COLOR_DIM
        end
    end

    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.ZIndex = 6
    
    btn.MouseButton1Click:Connect(function()
        local newState = not isOn
        Features[featureName] = newState
        updateVisual(newState)
        
        if featureName == "ThiefSpeed" then
            if newState then startSpeedWhileStealing() else stopSpeedWhileStealing() end
        end
    end)

    return updateVisual
end

local function createSlider(parent, labelText, minVal, maxVal, defaultValue, onChange)
    local container = Instance.new("Frame", parent)
    container.Size = UDim2.new(1, -16 * guiScale, 0, 50 * guiScale)
    container.Position = UDim2.new(0, 8 * guiScale, 0, 60 * guiScale)
    container.BackgroundColor3 = COLOR_BG_ROW
    container.BackgroundTransparency = 0.4
    container.BorderSizePixel = 0
    Instance.new("UICorner", container).CornerRadius = UDim.new(0, 6 * guiScale)
    
    local cStroke = Instance.new("UIStroke", container)
    cStroke.Thickness = 1.5 * guiScale
    cStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    cStroke.Color = COLOR_ACCENT

    local label = Instance.new("TextLabel", container)
    label.Size = UDim2.new(1, 0, 0, 14 * guiScale)
    label.BackgroundTransparency = 1
    label.Text = labelText .. " [" .. defaultValue .. "]"
    label.TextColor3 = COLOR_DIM
    label.Font = Enum.Font.GothamBold
    label.TextSize = 11 * guiScale
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Position = UDim2.new(0, 10, 0, 5)

    local sliderBg = Instance.new("Frame", container)
    sliderBg.Size = UDim2.new(1, -20, 0, 8 * guiScale)
    sliderBg.Position = UDim2.new(0, 10, 0, 26)
    sliderBg.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    sliderBg.BorderSizePixel = 0
    Instance.new("UICorner", sliderBg).CornerRadius = UDim.new(1, 0)

    local sliderFill = Instance.new("Frame", sliderBg)
    sliderFill.BackgroundColor3 = COLOR_ACCENT
    sliderFill.BorderSizePixel = 0
    Instance.new("UICorner", sliderFill).CornerRadius = UDim.new(1, 0)

    local thumb = Instance.new("Frame", sliderBg)
    thumb.Size = UDim2.new(0, 14 * guiScale, 0, 14 * guiScale)
    thumb.BackgroundColor3 = COLOR_GLOW
    thumb.BorderSizePixel = 0
    Instance.new("UICorner", thumb).CornerRadius = UDim.new(1, 0)
    
    local thumbGlow = Instance.new("UIStroke", thumb)
    thumbGlow.Color = COLOR_GLOW
    thumbGlow.Thickness = 2

    local currentValue = defaultValue
    local dragging = false

    local function updateSliderVisual(val)
        currentValue = math.clamp(val, minVal, maxVal)
        local relative = (currentValue - minVal) / (maxVal - minVal)
        label.Text = labelText .. " [" .. math.floor(currentValue) .. "]"
        sliderFill.Size = UDim2.new(relative, 0, 1, 0)
        thumb.Position = UDim2.new(relative, -7 * guiScale, 0, -3 * guiScale)
        if onChange then onChange(currentValue) end
    end

    local function getValueFromPosition(inputPos)
        local relX = (inputPos.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X
        relX = math.clamp(relX, 0, 1)
        return math.floor(minVal + (maxVal - minVal) * relX + 0.5)
    end

    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            updateSliderVisual(getValueFromPosition(input.Position))
        end
    end)

    thumb.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
        end
    end)

    sliderBg.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    thumb.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    local inputChangedConn
    inputChangedConn = UserInputService.InputChanged:Connect(function(input)
        if not dragging then return end
        if not container.Parent then 
            inputChangedConn:Disconnect()
            return 
        end
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            updateSliderVisual(getValueFromPosition(input.Position))
        end
    end)

    updateSliderVisual(defaultValue)
    return container
end

-- ─── 🏃‍♂️ HEAD SPEED COUNTER FEATURE ───────────────────────────────
local function createSpeedCounter()
    local currentLabel = nil

    local function attachCounter(character)
        if not character then return nil end
        local head = character:WaitForChild("Head", 5)
        if not head then return nil end
        
        -- Remove old counter if it exists
        if head:FindFirstChild("SpeedCounterGui") then
            head:FindFirstChild("SpeedCounterGui"):Destroy()
        end
        
        -- Create Billboard GUI
        local bb = Instance.new("BillboardGui")
        bb.Name = "SpeedCounterGui"
        bb.Adornee = head
        bb.Size = UDim2.new(4, 0, 0.5, 0)
        bb.StudsOffset = Vector3.new(0, 3, 0) -- Floats above head
        bb.AlwaysOnTop = true
        bb.MaxDistance = 100 -- Disappears if too far away
        bb.Parent = head
        
        -- Create Text Label
        local lbl = Instance.new("TextLabel", bb)
        lbl.Size = UDim2.new(1, 0, 1, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = "Speed: 0"
        lbl.TextColor3 = COLOR_GLOW
        -- Add black outline so it's readable in bright areas
        lbl.TextStrokeColor3 = Color3.new(0, 0, 0)
        lbl.TextStrokeTransparency = 0.3
        lbl.Font = Enum.Font.GothamBold
        lbl.TextScaled = true
        
        return lbl
    end

    -- Setup on current character
    currentLabel = attachCounter(Player.Character)
    
    -- Setup on respawn
    Player.CharacterAdded:Connect(function(char)
        currentLabel = attachCounter(char)
    end)

    -- Smoothly update the counter text
    RunService.RenderStepped:Connect(function()
        if not scriptActive or not currentLabel or not currentLabel.Parent then return end
        local char = Player.Character
        if not char then 
            currentLabel.Text = "Speed: 0"
            return 
        end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then 
            currentLabel.Text = "Speed: 0"
            return 
        end
        
        -- Calculate exact horizontal speed
        local vel = hrp.AssemblyLinearVelocity
        local speed = math.floor(Vector2.new(vel.X, vel.Z).Magnitude)
        
        currentLabel.Text = "Speed: " .. speed
    end)
end

createSpeedCounter()

