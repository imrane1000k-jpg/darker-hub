-- Helper to create a styled Toggle
local function makeToggle(parent, labelText, featureName)
    local frame = Instance.new("Frame", parent)
    frame.Size = UDim2.new(1, -16 * guiScale, 0, 40 * guiScale)
    frame.Position = UDim2.new(0, 8 * guiScale, 0, 10 * guiScale)
    frame.BackgroundColor3 = COLOR_BG_ROW
    frame.BackgroundTransparency = 0.4
    frame.BorderSizePixel = 0
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6 * guiScale)
    
    local fStroke = Instance.new("UIStroke", frame)
    fStroke.Thickness = 1.5 * guiScale
    fStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    fStroke.Color = COLOR_ACCENT

    local lbl = Instance.new("TextLabel", frame)
    lbl.Size = UDim2.new(0.6, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = labelText
    lbl.TextColor3 = COLOR_DIM
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 12 * guiScale
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Position = UDim2.new(0, 10, 0, 0)

    -- Toggle Switch BG
    local bg = Instance.new("Frame", frame)
    bg.Size = UDim2.new(0, 40 * guiScale, 0, 20 * guiScale)
    bg.Position = UDim2.new(1, -50 * guiScale, 0.5, -10 * guiScale)
    bg.BackgroundColor3 = COLOR_OFF
    bg.ZIndex = 4
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)

    -- Toggle Circle
    local circle = Instance.new("Frame", bg)
    circle.Size = UDim2.new(0, 16 * guiScale, 0, 16 * guiScale)
    circle.Position = UDim2.new(0, 2 * guiScale, 0.5, -8 * guiScale)
    circle.BackgroundColor3 = Color3.new(0.8, 0.8, 0.9)
    circle.ZIndex = 5
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)

    local isOn = false
    
    local function updateVisual(state)
        isOn = state
        if isOn then
            TweenService:Create(bg, TweenInfo.new(0.2), {BackgroundColor3 = COLOR_ACCENT}):Play()
            TweenService:Create(circle, TweenInfo.new(0.2), {Position = UDim2.new(1,-18*guiScale,0.5,-8*guiScale)}):Play()
            lbl.TextColor3 = COLOR_GLOW
        else
            TweenService:Create(bg, TweenInfo.new(0.2), {BackgroundColor3 = COLOR_OFF}):Play()
            TweenService:Create(circle, TweenInfo.new(0.2), {Position = UDim2.new(0,2*guiScale,0.5,-8*guiScale)}):Play()
            lbl.TextColor3 = COLOR_DIM
        end
    end

    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.ZIndex = 6
    
    btn.MouseButton1Click:Connect(function()
        local newState = not isOn
        Features[featureName] = newState
        updateVisual(newState)
        
        if featureName == "ThiefSpeed" then
            if newState then startSpeedWhileStealing() else stopSpeedWhileStealing() end
        end
    end)

    return updateVisual
end

-- Helper to create a styled Slider
local function createSlider(parent, labelText, minVal, maxVal, defaultValue, onChange)
    local container = Instance.new("Frame", parent)
    container.Size = UDim2.new(1, -16 * guiScale, 0, 50 * guiScale)
    container.Position = UDim2.new(0, 8 * guiScale, 0, 60 * guiScale)
    container.BackgroundColor3 = COLOR_BG_ROW
    container.BackgroundTransparency = 0.4
    container.BorderSizePixel = 0
    Instance.new("UICorner", container).CornerRadius = UDim.new(0, 6 * guiScale)
    
    local cStroke = Instance.new("UIStroke", container)
    cStroke.Thickness = 1.5 * guiScale
    cStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    cStroke.Color = COLOR_ACCENT

    local label = Instance.new("TextLabel", container)
    label.Size = UDim2.new(1, 0, 0, 14 * guiScale)
    label.BackgroundTransparency = 1
    label.Text = labelText .. " [" .. defaultValue .. "]"
    label.TextColor3 = COLOR_DIM
    label.Font = Enum.Font.GothamBold
    label.TextSize = 11 * guiScale
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Position = UDim2.new(0, 10, 0, 5)

    local sliderBg = Instance.new("Frame", container)
    sliderBg.Size = UDim2.new(1, -20, 0, 6 * guiScale)
    sliderBg.Position = UDim2.new(0, 10, 0, 25)
    sliderBg.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    Instance.new("UICorner", sliderBg).CornerRadius = UDim.new(1, 0)

    local sliderFill = Instance.new("Frame", sliderBg)
    sliderFill.Size = UDim2.new(0.5, 0, 1, 0)
    sliderFill.BackgroundColor3 = COLOR_ACCENT
    Instance.new("UICorner", sliderFill).CornerRadius = UDim.new(1, 0)

    local thumb = Instance.new("Frame", sliderBg)
    thumb.Size = UDim2.new(0, 12 * guiScale, 0, 12 * guiScale)
    thumb.Position = UDim2.new(0.5, -6 * guiScale, 0.5, -6 * guiScale)
    thumb.BackgroundColor3 = COLOR_GLOW
    Instance.new("UICorner", thumb).CornerRadius = UDim.new(1, 0)

    local currentValue = defaultValue
    local dragging = false

    local function updateSliderVisual(val)
        currentValue = val
        local relative = (val - minVal) / (maxVal - minVal)
        relative = math.clamp(relative, 0, 1)
        label.Text = labelText .. " [" .. math.floor(val) .. "]"
        sliderFill.Size = UDim2.new(relative, 0, 1, 0)
        thumb.Position = UDim2.new(relative, -6 * guiScale, 0.5, -6 * guiScale)
        if onChange then onChange(val) end
    end

    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then 
            dragging = true 
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then 
            dragging = false 
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local relative = (input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X
            local val = math.floor(minVal + (maxVal - minVal) * math.clamp(relative, 0, 1))
            updateSliderVisual(val)
        end
    end)

    updateSliderVisual(defaultValue)
    return container
end

